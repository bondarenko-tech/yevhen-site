{
  "extends": "astro/tsconfigs/strict",
  "include": ["src", ".astro/**/*.d.ts"],
  "exclude": ["dist", "public", "src/_legacy"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@lib/*": ["src/lib/*"],
      "@types/*": ["src/types/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@data/*": ["src/data/*"]
    }
  }
}