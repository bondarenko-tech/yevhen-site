---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";

const site = Astro.site ?? new URL("https://yevhenbondarenko.com");
const canonical = new URL("/kontakt/", site).toString();

const title = "Kontakt – Bondarenko Empfehlungen";
const description =
  "Kontaktinformationen zum Projekt Bondarenko Empfehlungen. Unabhängige Produktübersichten und technische Informationen.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ContactPage",
      "@id": `${canonical}#page`,
      url: canonical,
      name: "Kontakt",
      description,
      inLanguage: "de",
      isPartOf: { "@type": "WebSite", url: site.toString() },
      mainEntityOfPage: canonical,
    },
    {
      "@type": "Person",
      "@id": new URL("/#author", site).toString(),
      name: "Yevhen Bondarenko",
      jobTitle: "Affiliate-Publisher",
      url: site.toString(),
      image: new URL("/images/bondarenko.webp", site).toString(),
      email: "info@yevhenbondarenko.com",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Schloßberg 9",
        postalCode: "24955",
        addressLocality: "Harrislee",
        addressCountry: "DE",
      }
    }
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={[jsonLd]}
>
  <main class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    
    <header class="mb-12 text-center md:text-left">
      <h1 class="text-4xl font-extrabold text-neutral-900 mb-4 tracking-tight">
        Kontakt
      </h1>
      <p class="text-lg text-neutral-600">
        Informationen zum Projekt „Bondarenko Empfehlungen“.
      </p>
    </header>

    <div class="mb-12 flex justify-center md:justify-start">
      <img
        src="/images/bondarenko.webp"
        alt="Yevhen Bondarenko"
        width="420"
        height="280"
        class="rounded-3xl shadow-lg object-cover w-full max-w-[420px] aspect-video"
      />
    </div>

    <div class="bg-neutral-50 rounded-[2rem] border border-neutral-100 p-8 md:p-12 shadow-sm">

      <section class="mb-10 text-center md:text-left">
        <h2 class="text-2xl font-bold text-neutral-900 mb-4">
          Anfragen zum Projekt
        </h2>
        <p class="text-neutral-700 leading-relaxed mb-8">
          Bei allgemeinen Fragen zu den Inhalten können Sie eine Nachricht per E-Mail senden:
        </p>

        <div class="inline-flex items-center gap-4 bg-white px-6 py-4 rounded-2xl border border-neutral-200 shadow-sm">
          <span class="text-2xl">📧</span>
          <a href="mailto:info@yevhenbondarenko.com" class="text-blue-600 text-lg font-bold hover:underline">
            info@yevhenbondarenko.com
          </a>
        </div>
      </section>

      <hr class="border-neutral-200 mb-10" />

      <section class="space-y-6">
        <h2 class="text-xl font-bold text-neutral-900 mb-6 text-center md:text-left">
          Wichtige Hinweise
        </h2>

        <div class="grid gap-5">

          <div class="flex gap-4 p-5 bg-white rounded-2xl border border-neutral-100">
            <span class="text-red-500 font-bold text-xl">✕</span>
            <div>
              <p class="font-bold text-sm text-neutral-900">
                Keine individuelle Beratung
              </p>
              <p class="text-xs text-neutral-500 mt-1">
                Es erfolgt keine persönliche Kaufberatung oder technischer Support.
              </p>
            </div>
          </div>

          <div class="flex gap-4 p-5 bg-white rounded-2xl border border-neutral-100">
            <span class="text-red-500 font-bold text-xl">✕</span>
            <div>
              <p class="font-bold text-sm text-neutral-900">
                Keine Dienstleistungen
              </p>
              <p class="text-xs text-neutral-500 mt-1">
                Es werden keine Installationen oder Vor-Ort-Leistungen angeboten.
              </p>
            </div>
          </div>

          <div class="flex gap-4 p-5 bg-blue-50 rounded-2xl border border-blue-100">
            <span class="text-blue-600 font-bold text-xl">i</span>
            <div>
              <p class="font-bold text-sm text-blue-900 uppercase tracking-wide">
                Affiliate-Hinweis
              </p>
              <p class="text-xs text-blue-700 mt-1">
                Diese Website ist kein Online-Shop. Käufe erfolgen über externe Anbieter (z. B. Amazon).
              </p>
            </div>
          </div>

        </div>
      </section>
    </div>

    <div class="mt-16 text-center">
      <p class="text-sm text-neutral-400 mb-8 italic">
        Rechtlich verbindliche Angaben finden Sie im 
        <a href="/impressum/" class="underline font-medium hover:text-blue-600">
          Impressum
        </a>.
      </p>

      <a href="/" class="inline-flex items-center gap-3 text-sm font-bold text-neutral-900 hover:text-blue-600 group">
        ← Zurück zur Startseite
      </a>
    </div>

  </main>
</BaseLayout>