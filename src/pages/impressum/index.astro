---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";

const site = Astro.site ?? new URL("https://yevhenbondarenko.com");
const canonical = new URL("/impressum/", site).toString();

const title = "Impressum | Yevhen Bondarenko";
const description =
  "Rechtliche Angaben gemäß § 5 DDG – Betreiberinformationen und Kontakt von Yevhen Bondarenko.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#page`,
      url: canonical,
      name: title,
      isPartOf: { "@id": `${site}#website` },
      dateModified: new Date().toISOString().split("T")[0],
    },
    {
      "@type": "Person",
      "@id": `${site}#author`,
      name: "Yevhen Bondarenko",
      url: site.toString(),
      address: {
        "@type": "PostalAddress",
        streetAddress: "Schloßberg 9",
        postalCode: "24955",
        addressLocality: "Harrislee",
        addressCountry: "DE",
      },
      email: "info@yevhenbondarenko.com"
    }
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={[jsonLd]}>
  <main class="max-w-3xl mx-auto px-4 py-12 md:py-20 text-neutral-800">
    <h1 class="text-4xl font-black mb-10 tracking-tighter">Impressum</h1>

    <div class="space-y-10">
      <section>
        <h2 class="text-sm font-black uppercase tracking-widest text-blue-600 mb-3">
          Angaben gemäß § 5 DDG
        </h2>
        <p class="text-lg leading-relaxed font-medium">
          Yevhen Bondarenko<br />
          Schloßberg 9<br />
          24955 Harrislee<br />
          Deutschland
        </p>
        <p class="text-sm text-neutral-500 mt-3">
  Dieses Projekt wird unter dem Namen „Bondarenko Empfehlungen“ betrieben.
</p>
      </section>

      <section>
        <h2 class="text-sm font-black uppercase tracking-widest text-blue-600 mb-3">
          Kontakt
        </h2>
        <p class="leading-relaxed">
          E-Mail:
          <a href="mailto:info@yevhenbondarenko.com" class="text-neutral-900 font-bold underline hover:text-blue-600">
            info@yevhenbondarenko.com
          </a>
        </p>
        <p class="text-xs text-neutral-500 mt-2">
          Hinweis: Diese Website ist kein Online-Shop. Es erfolgen kein Verkauf, keine Lagerhaltung und kein Versand von Produkten.
        </p>
      </section>

      <section>
        <h2 class="text-sm font-black uppercase tracking-widest text-blue-600 mb-3">
          Umsatzsteuer-ID
        </h2>
        <p class="text-sm leading-relaxed">
          Umsatzsteuer-Identifikationsnummer gemäß § 27a Umsatzsteuergesetz:<br />
          <span class="font-mono font-bold text-neutral-900">DE400274226</span>
        </p>
      </section>

      <section>
        <h2 class="text-sm font-black uppercase tracking-widest text-blue-600 mb-3">
          Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV
        </h2>
        <p class="text-sm leading-relaxed font-medium">
          Yevhen Bondarenko<br />
          Schloßberg 9<br />
          24955 Harrislee
        </p>
      </section>

      <section class="p-6 bg-blue-50 rounded-2xl border border-blue-100">
        <h2 class="text-sm font-black uppercase tracking-widest text-blue-700 mb-3">
          Hinweis zu Partnerlinks
        </h2>
        <p class="text-xs text-blue-900 leading-relaxed">
          Diese Website enthält teilweise Partnerlinks, unter anderem zum Amazon-Partnerprogramm.
          Wenn über einen solchen Link ein Kauf erfolgt, kann eine Provision anfallen.
          Für Sie entstehen dadurch keine zusätzlichen Kosten.
        </p>
      </section>

      <section class="pt-6 border-t border-neutral-100">
        <h2 class="text-sm font-black uppercase tracking-widest text-neutral-900 mb-3">
          Verbraucherstreitbeilegung
        </h2>
        <p class="text-xs text-neutral-500 leading-relaxed">
          Es besteht keine Bereitschaft oder Verpflichtung zur Teilnahme an Streitbeilegungsverfahren
          vor einer Verbraucherschlichtungsstelle.
        </p>
      </section>
    </div>

    <div class="mt-20 text-[10px] text-neutral-400 uppercase tracking-widest">
      Stand: März 2026 | Deutschland
    </div>
  </main>
</BaseLayout>