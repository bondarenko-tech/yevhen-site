---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getBrandName, getBrandSlug } from "../../lib/brand";

const SITE =
  Astro.site?.toString().replace(/\/$/, "") ??
  "https://yevhenbondarenko.com";

const abs = (u: string) => new URL(u, SITE).toString();
const ensureSlash = (u: string) => (u.endsWith("/") ? u : `${u}/`);

const produkte = await getCollection("produkte");

const brandMap = new Map<string, { name: string; count: number }>();

for (const p of produkte) {
  const name = getBrandName(p.data.brand);
  if (!name) continue;
  const slug = getBrandSlug(p.data.brand);
  if (!slug) continue;

  const current = brandMap.get(slug);
  if (!current) brandMap.set(slug, { name, count: 1 });
  else brandMap.set(slug, { name: current.name, count: current.count + 1 });
}

const brands = Array.from(brandMap.entries())
  .map(([slug, v]) => ({ slug, name: v.name, count: v.count }))
  .sort((a, b) => a.name.localeCompare(b.name, "de"));

const canonical = ensureSlash(abs("/marken/"));
const title = "Marken – Übersicht";
const description = "Alle Marken aus den Produktseiten – mit Anzahl der Einträge.";
const breadcrumb = [
  { name: "Startseite", url: abs("/") },
  { name: "Marken", url: canonical },
];
---

<BaseLayout title={title} description={description} canonical={canonical} breadcrumb={breadcrumb}>
  <main class="mx-auto max-w-5xl px-4 py-10">
    <h1 class="text-3xl font-bold mb-6">Marken</h1>

    {brands.length === 0 ? (
      <p class="text-neutral-700">Noch keine Marken gefunden.</p>
    ) : (
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {brands.map((b) => (
          <a
            class="rounded-xl border bg-white p-4 hover:bg-neutral-50 transition"
            href={`/marken/${b.slug}/`}
          >
            <div class="font-semibold">{b.name}</div>
            <div class="text-sm text-neutral-600">{b.count} Produkte</div>
          </a>
        ))}
      </div>
    )}
  </main>
</BaseLayout>