---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import CategoryProductCard from "@components/CategoryProductCard.astro";

import { getCollection } from "astro:content";
import { normalizeAll } from "../../../lib/product-engine";

import { getBrandSlug, getBrandName } from "../../../lib/brand";

/* ───────── SITE ───────── */

const SITE =
  Astro.site?.toString().replace(/\/$/, "") ??
  "https://yevhenbondarenko.com";

const abs = (u: string) => new URL(u, SITE).toString();
const ensureSlash = (u: string) =>
  u.endsWith("/") ? u : `${u}/`;

/* ───────── Static paths ───────── */

export async function getStaticPaths() {

  const produkte = await getCollection("produkte");
  const normalized = normalizeAll(produkte);

  const map = new Map<string, { brand: string; kategorie: string }>();

  for (const p of normalized) {

    const brandSlug = getBrandSlug(p.brand);
    if (!brandSlug) continue;

    const key = `${brandSlug}__${p.kategorie}`;

    if (!map.has(key)) {
      map.set(key, {
        brand: brandSlug,
        kategorie: p.kategorie
      });
    }

  }

  return Array.from(map.values()).map((v) => ({
    params: {
      brand: v.brand,
      kategorie: v.kategorie
    }
  }));

}

/* ───────── Params ───────── */

const { brand, kategorie } =
  Astro.params as { brand: string; kategorie: string };

/* ───────── Content ───────── */

const produkte = await getCollection("produkte");
const normalized = normalizeAll(produkte);

const items = normalized.filter(
  (p) =>
    getBrandSlug(p.brand) === brand &&
    p.kategorie === kategorie
);

if (items.length === 0) {
  throw new Error("Seite nicht gefunden");
}

/* ───────── Brand name ───────── */

const brandName =
  getBrandName(items[0].brand) ?? brand;

/* ───────── SEO ───────── */

const canonical = ensureSlash(
  abs(`/marken/${brand}/${kategorie}/`)
);

const title =
  `${brandName} – ${kategorie} Geräte`;

const description =
  `Produkte der Marke ${brandName} in der Kategorie ${kategorie}.`;

/* ───────── Breadcrumb ───────── */

const breadcrumb = [
  { name: "Startseite", url: abs("/") },
  { name: "Marken", url: abs("/marken/") },
  { name: brandName, url: abs(`/marken/${brand}/`) },
  { name: kategorie, url: canonical },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumb={breadcrumb}
>

<main class="mx-auto max-w-5xl px-4 py-10">

<header class="mb-8">

<h1 class="text-3xl font-bold">
{brandName} – {kategorie}
</h1>

<p class="mt-2 text-neutral-700">
{items.length} Produkte
</p>

</header>

<section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

{items.map((p) => (
<CategoryProductCard p={p} />
))}

</section>

</main>

</BaseLayout>