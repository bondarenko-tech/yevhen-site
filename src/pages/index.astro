---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const vergleiche = await getCollection("vergleiche");

const latestVergleiche = vergleiche
  .sort((a, b) => new Date(b.data.datum ?? 0).getTime() - new Date(a.data.datum ?? 0).getTime())
  .slice(0, 3);

const title = "Technik verständlich erklärt | Yevhen Bondarenko";
const description =
  "Unabhängige Produktübersichten, technische Einordnung und kompakte Vergleiche für Smart Home, Netzwerk und Alltagstechnik.";
---

<BaseLayout title={title} description={description}>
  <!-- HERO -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-neutral-900 mb-6">
        Technik verständlich erklärt.<br />
        <span class="text-blue-600">Produkte klar eingeordnet.</span>
      </h1>

      <p class="text-lg text-neutral-600 max-w-3xl mx-auto leading-relaxed mb-10">
        Auf dieser Website finden Sie kompakte Produktübersichten, technische Erklärungen
        und verständliche Vergleiche zu Smart Home, Netzwerk und weiteren Geräten für den Alltag.
      </p>

      <div class="flex justify-center gap-4 flex-wrap">
        <a
          href="/verstehen/"
          class="px-6 py-3 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition"
        >
          Technik verstehen
        </a>

        <a
          href="/vergleiche/"
          class="px-6 py-3 rounded-xl border border-neutral-200 text-neutral-800 font-semibold hover:bg-neutral-50 transition"
        >
          Vergleiche ansehen
        </a>
      </div>
    </div>
  </section>

  <!-- EINORDNUNG -->
  <section class="py-16 bg-neutral-50">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-xl font-semibold text-neutral-900 mb-6">
        Worum es hier geht
      </h2>

      <p class="text-neutral-600 leading-relaxed">
        Diese Website ist kein Online-Shop. Hier werden keine Produkte verkauft,
        gelagert oder versendet.
      </p>

      <p class="text-neutral-600 leading-relaxed mt-4">
        Stattdessen finden Sie hier unabhängige Übersichten, Vergleiche und kurze Einordnungen
        auf Basis technischer Daten, Herstellerangaben und nachvollziehbarer Kriterien.
      </p>

      <p class="text-neutral-600 leading-relaxed mt-4">
        Ziel ist es, Produkte schneller einzuordnen und Unterschiede verständlich zu machen
        – ohne unnötige Fachsprache und ohne überladene Werbetexte.
      </p>
    </div>
  </section>

  <!-- THEMEN -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-xl font-semibold text-neutral-900 mb-10 text-center">
        Beliebte Themen
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <a href="/empfehlungen/netzwerk/" class="p-6 border rounded-xl hover:border-blue-200 hover:bg-blue-50/30 transition text-center">
          <div class="text-sm font-semibold text-neutral-800">WLAN & Netzwerk</div>
        </a>

        <a href="/empfehlungen/sicherheit/" class="p-6 border rounded-xl hover:border-blue-200 hover:bg-blue-50/30 transition text-center">
          <div class="text-sm font-semibold text-neutral-800">Sicherheit</div>
        </a>

        <a href="/empfehlungen/smart-home/" class="p-6 border rounded-xl hover:border-blue-200 hover:bg-blue-50/30 transition text-center">
          <div class="text-sm font-semibold text-neutral-800">Smart Home</div>
        </a>

        <a href="/empfehlungen/klima/" class="p-6 border rounded-xl hover:border-blue-200 hover:bg-blue-50/30 transition text-center">
          <div class="text-sm font-semibold text-neutral-800">Klima & Luft</div>
        </a>
      </div>
    </div>
  </section>

  <!-- VERTRAUEN / TRANSPARENZ -->
  <section class="py-16 bg-neutral-50">
    <div class="max-w-4xl mx-auto px-4">
      <div class="border border-neutral-200 rounded-2xl bg-white p-8 md:p-10">
        <h2 class="text-xl font-semibold text-neutral-900 mb-4">
          Transparenz und Einordnung
        </h2>

        <p class="text-neutral-600 leading-relaxed">
          Die Inhalte dienen der Orientierung und der verständlichen Einordnung von Geräten.
          Teilweise werden Partnerlinks verwendet, etwa zum Amazon-Partnerprogramm.
          Wenn über einen solchen Link ein Kauf erfolgt, kann eine Provision anfallen.
          Für Sie entstehen dadurch keine zusätzlichen Kosten.
        </p>

        <p class="text-neutral-600 leading-relaxed mt-4">
          Es handelt sich nicht um einen eigenen Handel: kein Warenbestand, kein Verkauf
          und kein Versand von Produkten.
        </p>
      </div>
    </div>
  </section>

  <!-- VERGLEICHE -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex justify-between items-center mb-10">
        <h2 class="text-xl font-semibold text-neutral-900">
          Aktuelle Vergleiche
        </h2>

        <a href="/vergleiche/" class="text-sm text-blue-600 hover:underline">
          Alle anzeigen →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {latestVergleiche.map((v) => (
          <a
            href={`/vergleiche/${v.slug}/`}
            class="block border rounded-xl overflow-hidden hover:shadow-sm transition bg-white"
          >
            <div class="aspect-video bg-neutral-100 flex items-center justify-center">
              {v.data.image ? (
                <img src={v.data.image} alt={v.data.title} class="object-contain max-h-full" />
              ) : (
                <span class="text-neutral-400 text-sm">Kein Bild</span>
              )}
            </div>

            <div class="p-4">
              <h3 class="text-sm font-semibold text-neutral-900 mb-2 line-clamp-2">
                {v.data.title}
              </h3>

              <p class="text-xs text-neutral-500 line-clamp-2">
                {v.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>