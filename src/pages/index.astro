---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const verstehen = await getCollection("verstehen");
const vergleiche = await getCollection("vergleiche");

const latestVergleiche = vergleiche
  .sort((a, b) => new Date(b.data.datum ?? 0).getTime() - new Date(a.data.datum ?? 0).getTime())
  .slice(0, 3);

const title = "Yevhen Bondarenko – Technik Empfehlungen & Netzwerk Lösungen";
const description = "Unabhängige Empfehlungen für Netzwerk, Smart Home und Sicherheit. Technik verständlich erklärt für Ihr Zuhause.";
---

<BaseLayout title={title} description={description}>
  
  <section class="bg-white pb-16 pt-20 md:pt-28">
    <div class="mx-auto max-w-7xl px-4 text-center">
      <div class="mb-6 inline-flex items-center rounded-full bg-blue-50 px-4 py-1.5 text-sm font-semibold text-blue-700 ring-1 ring-inset ring-blue-700/10">
        Unabhängige Technik-Einordnung
      </div>
      <h1 class="mx-auto mb-8 max-w-4xl text-4xl font-extrabold tracking-tight text-neutral-900 md:text-6xl">
        Die richtige Technik finden – <span class="text-blue-600">ohne Fehlkäufe.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-neutral-600">
        Ich helfe Ihnen, komplexe Technik zu verstehen. Hier finden Sie fundierte Empfehlungen für <strong>Netzwerk</strong> und <strong>Smart Home</strong> – ehrlich, kompakt und praxisnah.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/vergleiche/" class="rounded-xl bg-blue-600 px-8 py-4 text-sm font-bold text-white shadow-md transition-all hover:bg-blue-700 active:scale-95">
          Vergleiche ansehen
        </a>
        <a href="/verstehen/" class="rounded-xl border border-neutral-200 px-8 py-4 text-sm font-bold text-neutral-900 transition hover:bg-neutral-50 active:scale-95">
          Technik verstehen
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-neutral-50/50">
    <div class="mx-auto max-w-7xl px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-10 text-center">Beliebte Themen</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {[
          { name: 'WLAN & Mesh', icon: '📶', href: '/empfehlungen/wlan-mesh/' },
          { name: 'Sicherheit', icon: '🛡️', href: '/empfehlungen/sicherheit/' },
          { name: 'Smart Home', icon: '🏠', href: '/empfehlungen/smart-home/' },
          { name: 'Strom & Energie', icon: '⚡', href: '/empfehlungen/strom/' }
        ].map(topic => (
          <a href={topic.href} class="flex flex-col items-center p-6 bg-white border border-neutral-100 rounded-2xl hover:border-blue-200 hover:shadow-sm transition-all">
            <span class="text-3xl mb-3">{topic.icon}</span>
            <span class="font-bold text-neutral-800 text-sm md:text-base">{topic.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4">
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900">Aktuelle Vergleiche</h2>
        <a href="/vergleiche/" class="text-sm font-bold text-blue-600 hover:text-blue-700">Alle anzeigen →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestVergleiche.map(v => (
          <a href={`/vergleiche/${v.slug}/`} class="group flex flex-col bg-white border border-neutral-100 rounded-[24px] overflow-hidden hover:shadow-lg transition-all">
            <div class="aspect-video bg-neutral-50 flex items-center justify-center p-6">
              {v.data.image ? (
                <img src={v.data.image} alt={v.data.title} class="max-h-full object-contain group-hover:scale-105 transition-transform" />
              ) : (
                <span class="text-4xl text-neutral-200">📊</span>
              )}
            </div>
            <div class="p-6">
              <h3 class="font-bold text-neutral-900 mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">
                {v.data.title}
              </h3>
              <p class="text-sm text-neutral-500 line-clamp-2">
                {v.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-4xl px-4">
      <div class="rounded-[32px] bg-blue-50 border border-blue-100 p-8 md:p-16 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-4">Bereit für ein smartes Upgrade?</h2>
        <p class="text-neutral-600 mb-8 max-w-xl mx-auto">
          Finden Sie die passenden Geräte in meinen handverlesenen Empfehlungslisten.
        </p>
        <a href="/empfehlungen/" class="inline-block rounded-xl bg-blue-600 px-10 py-4 text-sm font-bold text-white shadow-md hover:bg-blue-700 transition-all">
          Empfehlungen ansehen
        </a>
      </div>
    </div>
  </section>

</BaseLayout>