---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const vergleiche = await getCollection("vergleiche");

const latestVergleiche = vergleiche
  .sort((a, b) => new Date(b.data.datum ?? 0).getTime() - new Date(a.data.datum ?? 0).getTime())
  .slice(0, 3);

const title = "Technik einfach erklärt | Bondarenko Empfehlungen";
const description = "Ich sammle technische Informationen und erkläre sie kurz und verständlich – ohne Werbung, ohne Fachsprache.";
---

<BaseLayout title={title} description={description}>

  <!-- HERO -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-4 text-center">

      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-neutral-900 mb-6">
        Technik verstehen.<br />
        <span class="text-blue-600">Einfach erklärt.</span>
      </h1>

      <p class="text-lg text-neutral-600 max-w-2xl mx-auto leading-relaxed mb-10">
        Ich sammle technische Informationen und bereite sie so auf,  
        dass man schnell versteht, was ein Gerät kann –  
        ohne lange Tests oder komplizierte Begriffe.
      </p>

      <div class="flex justify-center gap-4 flex-wrap">
        <a href="/verstehen/" class="px-6 py-3 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition">
          Technik verstehen
        </a>

        <a href="/vergleiche/" class="px-6 py-3 rounded-xl border border-neutral-200 text-neutral-800 font-semibold hover:bg-neutral-50 transition">
          Vergleiche ansehen
        </a>
      </div>

    </div>
  </section>

  <!-- WHY -->
  <section class="py-16 bg-neutral-50">
    <div class="max-w-3xl mx-auto px-4 text-center">

      <h2 class="text-xl font-semibold text-neutral-900 mb-6">
        Worum es hier geht
      </h2>

      <p class="text-neutral-600 leading-relaxed">
        Diese Seite ist kein Online-Shop und kein klassischer Technik-Blog.
      </p>

      <p class="text-neutral-600 leading-relaxed mt-4">
        Ich teste keine Geräte und gebe keine persönlichen Empfehlungen ab.
      </p>

      <p class="text-neutral-600 leading-relaxed mt-4">
        Stattdessen sammle ich Informationen und erkläre sie so,
        dass man schneller versteht, worauf es ankommt.
      </p>

    </div>
  </section>

  <!-- THEMEN -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">

      <h2 class="text-xl font-semibold text-neutral-900 mb-10 text-center">
        Themen
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">

        <a href="/empfehlungen/netzwerk/" class="p-6 border rounded-xl hover:border-blue-200 transition text-center">
          <div class="text-sm font-semibold text-neutral-800">WLAN & Netzwerk</div>
        </a>

        <a href="/empfehlungen/sicherheit/" class="p-6 border rounded-xl hover:border-blue-200 transition text-center">
          <div class="text-sm font-semibold text-neutral-800">Sicherheit</div>
        </a>

        <a href="/empfehlungen/smart-home/" class="p-6 border rounded-xl hover:border-blue-200 transition text-center">
          <div class="text-sm font-semibold text-neutral-800">Smart Home</div>
        </a>

        <a href="/empfehlungen/klima/" class="p-6 border rounded-xl hover:border-blue-200 transition text-center">
          <div class="text-sm font-semibold text-neutral-800">Klima & Luft</div>
        </a>

      </div>

    </div>
  </section>

  <!-- VERGLEICHE -->
  <section class="py-20 bg-neutral-50">
    <div class="max-w-6xl mx-auto px-4">

      <div class="flex justify-between items-center mb-10">
        <h2 class="text-xl font-semibold text-neutral-900">
          Aktuelle Vergleiche
        </h2>

        <a href="/vergleiche/" class="text-sm text-blue-600 hover:underline">
          Alle anzeigen →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-8">

        {latestVergleiche.map(v => (
          <a href={`/vergleiche/${v.slug}/`} class="block border rounded-xl overflow-hidden hover:shadow-sm transition bg-white">

            <div class="aspect-video bg-neutral-100 flex items-center justify-center">
              {v.data.image ? (
                <img src={v.data.image} alt={v.data.title} class="object-contain max-h-full" />
              ) : (
                <span class="text-neutral-400 text-sm">Kein Bild</span>
              )}
            </div>

            <div class="p-4">
              <h3 class="text-sm font-semibold text-neutral-900 mb-2 line-clamp-2">
                {v.data.title}
              </h3>

              <p class="text-xs text-neutral-500 line-clamp-2">
                {v.data.description}
              </p>
            </div>

          </a>
        ))}

      </div>

    </div>
  </section>

</BaseLayout>