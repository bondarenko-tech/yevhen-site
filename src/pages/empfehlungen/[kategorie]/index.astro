    ],
    compareLinks: [
      {
        href: "/verstehen/smarte-steckdose/",
        label: "Smarte Steckdosen einfach erklärt",
      },
      {
        href: "/vergleiche/smart-lock-vs-tuerklingel-vs-kamera/",
        label: "Smart Lock, Türklingel oder Kamera vergleichen",
      },
      {
        href: "/verstehen/",
        label: "Weitere Smart-Home-Erklärungen ansehen",
      },
    ],
  },

  netzwerk: {
    label: "WLAN & Netzwerk",
    title: "WLAN- und Netzwerkgeräte für zuhause",
    intro:
      "Hier finden Sie Empfehlungen zu WLAN-Repeatern, Mesh-Lösungen, Routern und Netzwerkgeräten für stabileres Internet in Wohnung, Haus und Homeoffice.",
    problemTitle: "Wenn WLAN nicht überall zuverlässig funktioniert",
    problemText:
      "Schwaches WLAN entsteht oft nicht durch den Internetanschluss selbst, sondern durch Wände, Entfernung, falsche Platzierung oder zu viele Geräte. Deshalb ist es wichtig, zwischen Repeater, Mesh, Powerline und Router-Lösung zu unterscheiden.",
    decisionText:
      "Für kleine Funklöcher reicht oft ein Repeater. Bei mehreren Etagen oder großen Wohnungen ist Mesh meist sinnvoller. Powerline kann helfen, ist aber stark von der Stromverkabelung abhängig.",
    useCases: [
      "besseres WLAN im Homeoffice",
      "stabilere Verbindung in mehreren Räumen",
      "WLAN-Probleme in Altbau oder Keller lösen",
      "Streaming, Videocalls und Smart Home stabiler nutzen",
    ],
    compareLinks: [
      {
        href: "/vergleiche/wlan-repeater-vergleich/",
        label: "WLAN-Repeater vergleichen",
      },
      {
        href: "/verstehen/mesh-vs-repeater/",
        label: "Mesh oder Repeater verstehen",
      },
      {
        href: "/verstehen/powerline-vs-mesh/",
        label: "Powerline oder Mesh erklären lassen",
      },
    ],
  },

  strom: {
    label: "Strom & Energie",
    title: "Stromgeräte, Steckdosen und Powerstations",
    intro:
      "Hier finden Sie Geräte rund um Strom, Energie, Steckdosen, Ladegeräte und mobile Stromversorgung – verständlich eingeordnet für Alltag, Zuhause und unterwegs.",
    problemTitle: "Stromlösungen müssen zuverlässig und sicher sein",
    problemText:
      "Bei Stromprodukten zählt nicht nur der Preis. Wichtig sind Sicherheit, Leistung, Anschlussmöglichkeiten und der konkrete Einsatzbereich. Eine smarte Steckdose, ein Ladegerät oder eine Powerstation erfüllen völlig unterschiedliche Aufgaben.",
    decisionText:
      "Vor dem Kauf sollte klar sein, ob Sie ein Gerät für den Alltag, für Notstrom, für Camping oder für mehrere Verbraucher gleichzeitig benötigen. Genau davon hängt ab, ob eine einfache Steckdose reicht oder eine stärkere Lösung sinnvoller ist.",
    useCases: [
      "Geräte sicher und bequem mit Strom versorgen",
      "mehr Steckplätze im Alltag nutzen",
      "mobile Energie für Camping oder Notfälle",
      "Ladegeräte, Steckdosen und Powerstations besser einordnen",
    ],
    compareLinks: [
      {
        href: "/verstehen/steckdosenleiste/",
        label: "Steckdosenleisten richtig verstehen",
      },
      {
        href: "/verstehen/smarte-steckdose/",
        label: "Smarte Steckdose einfach erklärt",
      },
      {
        href: "/vergleiche/brennenstuhl-eco-vs-premium-steckdosenleiste/",
        label: "Brennenstuhl Steckdosenleisten vergleichen",
      },
    ],
  },

  klima: {
    label: "Klima & Luft",
    title: "Klima- und Luftgeräte für zuhause",
    intro:
      "Hier finden Sie Empfehlungen zu mobilen Klimageräten, Luftlösungen, Heizlüftern und Geräten für ein angenehmeres Raumklima.",
    problemTitle: "Raumklima ist im Alltag wichtiger als reine Leistung",
    problemText:
      "Bei Klima- und Luftgeräten kommt es nicht nur auf Watt, BTU oder technische Daten an. Entscheidend ist, ob das Gerät zum Raum passt, wie laut es ist und ob es im Alltag wirklich entlastet.",
    decisionText:
      "Für kleine Räume reicht oft eine kompakte Lösung. Größere Räume brauchen mehr Leistung. Bei Schlafzimmer oder Büro sind Lautstärke, Bedienung und Energieverbrauch besonders wichtig.",
    useCases: [
      "Räume im Sommer angenehmer kühlen",
      "gezielte Zusatzwärme im Winter nutzen",
      "Luftqualität und Komfort verbessern",
      "passende Geräte für Schlafzimmer, Büro oder Wohnzimmer finden",
    ],
    compareLinks: [
      {
        href: "/verstehen/",
        label: "Technik einfach erklärt",
      },
      {
        href: "/vergleiche/",
        label: "Weitere Vergleiche ansehen",
      },
    ],
  },

  beleuchtung: {
    label: "Beleuchtung",
    title: "Beleuchtung und smarte Lichtlösungen",
    intro:
      "Hier finden Sie Empfehlungen zu Lampen, LED-Lösungen und smarter Beleuchtung für mehr Komfort, Atmosphäre und praktische Nutzung zuhause.",
    problemTitle: "Gutes Licht muss zum Raum passen",
    problemText:
      "Bei Beleuchtung geht es nicht nur um Helligkeit. Farbtemperatur, Steuerung, Montage und Einsatzbereich entscheiden darüber, ob eine Lampe im Alltag wirklich angenehm ist.",
    decisionText:
      "Smarte Beleuchtung lohnt sich besonders, wenn Licht automatisiert oder per App gesteuert werden soll. Für einfache Zwecke reicht oft eine klassische LED-Lösung.",
    useCases: [
      "angenehmeres Licht im Wohnbereich",
      "smarte Steuerung per App oder Sprache",
      "LED-Lösungen für Küche, Schrank oder Flur",
      "Atmosphäre und Alltagstauglichkeit kombinieren",
    ],
    compareLinks: [
      {
        href: "/verstehen/",
        label: "Technik einfach erklärt",
      },
      {
        href: "/empfehlungen/smart-home/",
        label: "Weitere Smart-Home-Geräte ansehen",
      },
    ],
  },

  sonstiges: {
    label: "Weitere Technik",
    title: "Weitere Technikprodukte im Überblick",
    intro:
      "Hier finden Sie weitere Technikprodukte, die nicht klar in eine einzelne Hauptkategorie passen, aber im Alltag trotzdem nützlich sein können.",
    problemTitle: "Nicht jedes nützliche Gerät passt in eine feste Kategorie",
    problemText:
      "Manche Produkte sind weder klassisches Smart Home noch reine Sicherheitstechnik. Trotzdem können sie im Alltag sinnvoll sein – etwa Kopfhörer, Tracker, Übersetzer, Reinigungsgeräte oder andere praktische Techniklösungen.",
    decisionText:
      "Bei solchen Geräten ist besonders wichtig, ob der Nutzen wirklich klar ist. Nicht jede Zusatzfunktion ist relevant. Entscheidend ist, ob das Produkt ein konkretes Problem löst.",
    useCases: [
      "praktische Technik für Alltag und Haushalt finden",
      "Geräte besser einordnen, die nicht in Standardkategorien passen",
      "Fehlkäufe bei Spezialprodukten vermeiden",
      "nützliche Produkte mit echtem Alltagseffekt entdecken",
    ],
    compareLinks: [
      {
        href: "/vergleiche/",
        label: "Alle Vergleiche ansehen",
      },
      {
        href: "/verstehen/",
        label: "Technik einfach erklärt",
      },
    ],
  },
};

const currentCategory: CategoryInfo = categoryMap[kategorie] ?? {
  label: "Technik",
  title: "Technikprodukte im Überblick",
  intro:
    "Hier finden Sie Produktübersichten und verständliche Einordnungen zu ausgewählten Technikgeräten für den Alltag.",
  problemTitle: "Technik sollte ein konkretes Problem lösen",
  problemText:
    "Nicht jedes Gerät ist automatisch sinnvoll. Wichtig ist, ob es im Alltag wirklich hilft, zuverlässig funktioniert und zum eigenen Bedarf passt.",
  decisionText:
    "Vergleichen Sie vor dem Kauf Funktionen, Einsatzbereich und mögliche Einschränkungen. So vermeiden Sie Fehlkäufe und finden schneller eine passende Lösung.",
  useCases: [
    "Geräte besser vergleichen",
    "typische Probleme im Alltag lösen",
    "passende Funktionen schneller verstehen",
    "unnötige Fehlkäufe vermeiden",
  ],
  compareLinks: [
    { href: "/vergleiche/", label: "Vergleiche ansehen" },
    { href: "/verstehen/", label: "Technik einfach erklärt" },
  ],
};

const title = `${currentCategory.title} | Bondarenko Empfehlungen`;
const description = currentCategory.intro;
const canonical = `${SITE}/empfehlungen/${kategorie}/`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  robots={filtered.length > 0 ? "index, follow" : "noindex, follow"}
>
  <main class="mx-auto max-w-6xl px-4 py-10 md:py-14">
    <header class="mb-12 max-w-3xl">
      <p class="mb-3 text-sm font-semibold text-blue-700">
        {currentCategory.label}
      </p>

      <h1 class="mb-4 text-3xl font-bold tracking-tight text-neutral-950 md:text-5xl">
        {currentCategory.title}
      </h1>

      <p class="text-base leading-relaxed text-neutral-700 md:text-lg">
        {currentCategory.intro}
      </p>
    </header>

    <section class="mb-12 grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
        <h2 class="mb-4 text-xl font-semibold text-neutral-950">
          {currentCategory.problemTitle}
        </h2>

        <p class="mb-5 leading-relaxed text-neutral-700">
          {currentCategory.problemText}
        </p>

        <ul class="space-y-2 text-sm leading-relaxed text-neutral-700">
          {currentCategory.useCases.map((item: string) => (
            <li>• {item}</li>
          ))}
        </ul>
      </div>

      <div class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6">
        <h2 class="mb-4 text-xl font-semibold text-neutral-950">
          Vor dem Kauf richtig einordnen
        </h2>

        <p class="mb-5 leading-relaxed text-neutral-700">
          {currentCategory.decisionText}
        </p>

        <div class="flex flex-col gap-3">
          {currentCategory.compareLinks.map(
            (link: { href: string; label: string }) => (
              <a
                href={link.href}
                class="text-sm font-semibold text-blue-700 hover:underline"
              >
                → {link.label}
              </a>
            )
          )}
        </div>
      </div>
    </section>

    {filtered.length > 0 ? (
      <section>
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <h2 class="text-2xl font-semibold text-neutral-950">
              Passende Geräte
            </h2>
            <p class="mt-2 text-sm text-neutral-600">
              Ausgewählte Produktübersichten aus dieser Kategorie.
            </p>
          </div>

          <span class="text-sm text-neutral-500">
            {filtered.length} {filtered.length === 1 ? "Gerät" : "Geräte"}
          </span>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {filtered.map((p) => (
            <a
              href={`/empfehlungen/${kategorie}/${p.slug}/`}
              class="group block rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
            >
              <div class="mb-4 flex aspect-[4/3] items-center justify-center overflow-hidden rounded-xl bg-neutral-50">
                {typeof p.data.image === "string" && p.data.image.length > 0 ? (
  <img
    src={p.data.image}
    alt={p.data.title}
    class="max-h-full object-contain transition group-hover:scale-[1.02]"
    loading="lazy"
  />
) : (
  <span class="text-sm text-neutral-400">
    Kein Bild verfügbar
  </span>
)}
              </div>

              <h3 class="mb-2 line-clamp-2 font-semibold text-neutral-950">
                {p.data.title}
              </h3>

              <p class="line-clamp-3 text-sm leading-relaxed text-neutral-600">
                {p.data.teaser || p.data.description}
              </p>

              <div class="mt-4 text-sm font-semibold text-blue-700">
                Mehr erfahren →
              </div>
            </a>
          ))}
        </div>
      </section>
    ) : (
      <section class="rounded-2xl border border-neutral-200 bg-white p-6">
        <h2 class="mb-3 text-xl font-semibold text-neutral-950">
          Noch keine Geräte in dieser Kategorie
        </h2>

        <p class="leading-relaxed text-neutral-600">
          Für diese Kategorie sind aktuell noch keine Produktübersichten veröffentlicht.
          Nutzen Sie in der Zwischenzeit die Vergleiche oder die Erklärseiten.
        </p>

        <div class="mt-5 flex flex-col gap-2">
          <a
            href="/vergleiche/"
            class="text-sm font-semibold text-blue-700 hover:underline"
          >
            → Zu den Vergleichen
          </a>
          <a
            href="/verstehen/"
            class="text-sm font-semibold text-blue-700 hover:underline"
          >
            → Technik einfach erklärt
          </a>
        </div>
      </section>
    )}

    <section class="mt-16 rounded-2xl border border-neutral-200 bg-neutral-50 p-6 md:p-8">
      <h2 class="mb-3 text-xl font-semibold text-neutral-950">
        Noch unsicher?
      </h2>

      <p class="mb-5 max-w-3xl text-sm leading-relaxed text-neutral-700 md:text-base">
        Wenn Sie noch nicht sicher sind, welches Gerät wirklich zu Ihrer Situation passt,
        ist ein Vergleich oft sinnvoller als ein schneller Einzelkauf. So lassen sich
        Unterschiede bei Preis, Funktionen, Installation und Alltagstauglichkeit besser erkennen.
      </p>

      <div class="flex flex-wrap gap-3">
        <a
          href="/vergleiche/"
          class="inline-flex items-center justify-center rounded-xl bg-neutral-900 px-5 py-3 font-semibold text-white transition hover:bg-blue-700"
        >
          Vergleiche ansehen
        </a>

        <a
          href="/verstehen/"
          class="inline-flex items-center justify-center rounded-xl border border-neutral-300 bg-white px-5 py-3 font-semibold text-neutral-900 transition hover:bg-neutral-100"
        >
          Technik verstehen
        </a>
      </div>
    </section>
  </main>
</BaseLayout>