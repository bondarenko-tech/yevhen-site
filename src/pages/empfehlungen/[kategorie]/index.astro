---
export const prerender = true;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

type CategoryInfo = {
  label: string;
  title: string;
  intro: string;
  problemTitle: string;
  problemText: string;
  decisionText: string;
  useCases: string[];
  compareLinks: { href: string; label: string }[];
};

export async function getStaticPaths() {
  const produkte = await getCollection("produkte");

  const kategorien = [
    ...new Set(produkte.map((p) => p.data.kategorie).filter(Boolean)),
  ];

  return kategorien.map((kategorie) => ({
    params: { kategorie },
  }));
}

const SITE =
  Astro.site?.toString().replace(/\/$/, "") ??
  "https://yevhenbondarenko.com";

const { kategorie } = Astro.params as { kategorie: string };

const produkte = await getCollection("produkte");

const filtered = produkte
  .filter((p) => p.data.kategorie === kategorie)
  .sort((a, b) => {
    const aFeatured = a.data.featured ? 1 : 0;
    const bFeatured = b.data.featured ? 1 : 0;

    if (aFeatured !== bFeatured) return bFeatured - aFeatured;

    return (
      new Date(b.data.datum ?? 0).getTime() -
      new Date(a.data.datum ?? 0).getTime()
    );
  });

const categoryMap: Record<string, CategoryInfo> = {
  sicherheit: {
    label: "Sicherheit",
    title: "Sicherheitsgeräte für Haus und Wohnung",
    intro:
      "Hier finden Sie verständliche Empfehlungen zu Kameras, Video-Türklingeln, smarten Türschlössern und weiteren Sicherheitslösungen für den Alltag.",
    problemTitle: "Mehr Kontrolle am Eingang und zuhause",
    problemText:
      "Viele Sicherheitsgeräte klingen auf dem Papier ähnlich. In der Praxis unterscheiden sie sich aber deutlich: Manche eignen sich eher für die Wohnung, andere für ein Haus mit Eingangstür, Garten oder Einfahrt. Wichtig ist deshalb nicht nur die Kameraauflösung, sondern auch Installation, App, Benachrichtigungen, Speicher und mögliche Folgekosten.",
    decisionText:
      "Wählen Sie ein Sicherheitsgerät nicht nur nach Preis oder Marke. Entscheidend ist, ob es zu Ihrer Wohnsituation passt: Akku oder Kabel, App oder Monitor, mit oder ohne Abo, Innenbereich oder Außenbereich.",
    useCases: [
      "sehen, wer vor der Tür steht",
      "Pakete und Besucher besser im Blick behalten",
      "Eingangsbereich, Flur oder Garten überwachen",
      "mehr Sicherheit ohne komplizierte Installation",
    ],
    compareLinks: [
      {
        href: "/vergleiche/beste-video-tuerklingel-2026/",
        label: "Beste Video-Türklingeln 2026 vergleichen",
      },
      {
        href: "/vergleiche/video-tuerklingel-ohne-abo/",
        label: "Video-Türklingeln ohne Abo ansehen",
      },
      {
        href: "/vergleiche/video-tuerklingel-unter-100-euro/",
        label: "Günstige Video-Türklingeln unter 100 Euro",
      },
    ],
  },

  "smart-home": {
    label: "Smart Home",
    title: "Smart-Home-Geräte für den Alltag",
    intro:
      "Hier finden Sie Smart-Home-Geräte, die den Alltag einfacher machen können – von Sprachassistenten über Steckdosen bis zu vernetzten Geräten für zuhause.",
    problemTitle: "Smart Home soll helfen, nicht komplizierter werden",
    problemText:
      "Viele Smart-Home-Produkte versprechen Komfort, sind aber im Alltag nur dann sinnvoll, wenn Einrichtung, App und Kompatibilität wirklich passen. Gerade Einsteiger sollten nicht mit zu vielen Systemen gleichzeitig starten.",
    decisionText:
      "Achten Sie vor allem darauf, ob ein Gerät zu Ihrem bestehenden System passt. Alexa, Google Home, Apple Home oder ein eigenes Hersteller-System können im Alltag einen großen Unterschied machen.",
    useCases: [
      "Licht und Geräte per Sprache steuern",
      "einfache Routinen im Alltag nutzen",
      "Steckdosen, Lautsprecher oder Sensoren verbinden",
