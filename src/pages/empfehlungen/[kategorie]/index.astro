---
export const prerender = true;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const produkte = await getCollection("produkte");

  const kategorien = [...new Set(produkte.map((p) => p.data.kategorie).filter(Boolean))];

  return kategorien.map((kategorie) => ({
    params: { kategorie },
  }));
}

const { kategorie } = Astro.params;

const produkte = await getCollection("produkte");
const filtered = produkte.filter((p) => p.data.kategorie === kategorie);

/* SEO */
const title = `Beste ${kategorie} Geräte 2026 – Empfehlungen & Vergleich`;
const description = `Die besten ${kategorie} Lösungen im Überblick. Wir zeigen dir, welche Geräte sich wirklich lohnen.`;
---

<BaseLayout title={title} description={description}>

<main class="max-w-5xl mx-auto px-4 py-12">

  <!-- HERO -->
  <header class="mb-10">
    <h1 class="text-3xl font-bold mb-4">
      Beste {kategorie} Geräte im Vergleich
    </h1>

    <p class="text-neutral-600">
      Wir zeigen dir, welche Geräte in dieser Kategorie wirklich sinnvoll sind 
      und worauf du beim Kauf achten solltest.
    </p>
  </header>

  <!-- 🔥 ВАЖНЫЙ SEO БЛОК -->
  <section class="mb-12">
    <h2 class="text-xl font-semibold mb-4">
      Wann lohnt sich diese Technik?
    </h2>

    <p class="text-neutral-700 mb-3">
      Geräte aus dieser Kategorie sind besonders dann sinnvoll, wenn typische Probleme 
      im Alltag gelöst werden sollen. Dazu gehören zum Beispiel schlechte Verbindungen,
      ineffiziente Lösungen oder unnötig komplizierte Setups.
    </p>

    <p class="text-neutral-700">
      Wichtig ist, dass du nicht einfach das teuerste Produkt kaufst,
      sondern eine Lösung wählst, die zu deiner Wohnsituation passt.
    </p>
  </section>

  <!-- ПРОДУКТЫ -->
  <section class="grid md:grid-cols-2 gap-6">

    {filtered.slice(0, 20).map(p => (
      <a
        href={`/empfehlungen/${kategorie}/${p.slug}/`}
        class="border rounded-xl p-4 hover:shadow-sm transition block"
      >
        <img src={p.data.image} alt={p.data.title} class="mb-3" />

        <h3 class="font-semibold text-neutral-900">
          {p.data.title}
        </h3>

        <p class="text-sm text-neutral-600 mt-1">
          {p.data.teaser}
        </p>
      </a>
    ))}

  </section>

</main>

</BaseLayout>