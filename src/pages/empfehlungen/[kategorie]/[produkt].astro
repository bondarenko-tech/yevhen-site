---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { normalizeProduct } from "@lib/product-engine";

export async function getStaticPaths() {
  const p = await getCollection("produkte");
  return p.map(e => ({ params: { kategorie: e.data.kategorie, produkt: e.slug } }));
}

const { kategorie, produkt } = Astro.params;
const entries = await getCollection("produkte");
const entry = entries.find(e => e.slug === produkt && e.data.kategorie === kategorie);

if (!entry) throw new Error("404");

const { Content } = await entry.render();
const n = normalizeProduct(entry);

/* SAFE ARRAYS */
const pros = n.pros ?? [];
const cons = n.cons ?? [];

/* PRICE */
const price = typeof n.preis === "number"
  ? new Intl.NumberFormat("de-DE", {
      style: "currency",
      currency: "EUR"
    }).format(n.preis)
  : null;
---

<BaseLayout title={n.title}>
  <main class="max-w-[1050px] mx-auto px-4 py-10 antialiased text-[14px] text-zinc-800 bg-white font-sans">
    
    <!-- HEADER -->
    <header class="flex justify-between items-end border-b-2 border-zinc-950 pb-4 mb-10">
      <div>
        <div class="text-[10px] font-mono text-zinc-400 uppercase tracking-widest mb-1">
          {kategorie} // {n.brand?.name ?? ""}
        </div>

        <h1 class="text-2xl md:text-3xl font-black tracking-tight text-zinc-950">
          {n.title}
        </h1>
      </div>

      <div class="text-right font-mono text-[10px] text-zinc-400 hidden md:block">
        REF: {entry.slug} <br/> 
        {new Date().getFullYear()}
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <!-- LEFT -->
      <div class="lg:col-span-4 order-2 lg:order-1">
        <div class="sticky top-8 space-y-6">

          <!-- SPECS -->
          <div class="bg-zinc-50 border border-zinc-200 p-4 rounded-sm">
            <h2 class="text-[10px] font-bold uppercase tracking-widest mb-4 border-b border-zinc-200 pb-2">
              Technische Daten
            </h2>

            <table class="w-full text-[12px]">
              <tbody class="divide-y divide-zinc-100">
                {n.kurzfakten?.map(k => (
                  <tr>
                    <td class="py-2 text-zinc-500 uppercase text-[9px] font-bold">{k.label}</td>
                    <td class="py-2 text-zinc-950 font-bold text-right">{k.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- CTA -->
          <div>
            <a 
              href={n.linkExtern} 
              target="_blank"
              rel="nofollow sponsored noopener"
              class="block w-full bg-[#FF9900] hover:bg-[#E68A00] text-zinc-950 text-center py-4 font-black uppercase text-[11px] rounded-sm transition-all shadow-md active:scale-[0.98]"
            >
              Bei Amazon ansehen →
            </a>

            {price && (
              <div class="text-center mt-2 text-sm font-bold text-zinc-900">
                {price}
              </div>
            )}

            <p class="text-[9px] text-zinc-400 mt-2 text-center leading-tight">
              * Affiliate-Link. Kein Verkauf über diese Website.
            </p>
          </div>

          <!-- PROS -->
          {pros.length > 0 && (
            <div>
              <h4 class="text-[10px] font-bold uppercase text-zinc-400 mb-2">Vorteile</h4>
              <ul class="space-y-1 text-sm">
                {pros.map(p => (
                  <li class="flex gap-2 text-zinc-900 font-medium">
                    <span class="text-green-600">+</span> {p}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- CONS -->
          {cons.length > 0 && (
            <div>
              <h4 class="text-[10px] font-bold uppercase text-zinc-400 mb-2">Hinweise</h4>
              <ul class="space-y-1 text-sm">
                {cons.map(c => (
                  <li class="flex gap-2 text-zinc-500">
                    <span>−</span> {c}
                  </li>
                ))}
              </ul>
            </div>
          )}

        </div>
      </div>

      <!-- RIGHT -->
      <div class="lg:col-span-8 order-1 lg:order-2">

        <!-- TEASER -->
        <div class="mb-10 text-[15px] leading-relaxed font-medium text-zinc-900 border-l-4 border-zinc-950 pl-6 py-2 bg-zinc-50/50">
          Kurz gesagt: {n.teaser}
        </div>

        <!-- NOTE -->
        <div class="mb-12 p-6 bg-zinc-950 text-zinc-100 rounded-sm">
          <h3 class="text-[10px] font-bold uppercase tracking-widest mb-3 text-zinc-400">
            Hinweis
          </h3>
          <p class="text-[13px] leading-relaxed">
            Für komplexe Netzwerke (z. B. VLAN oder spezielle VPN-Setups) sind die Möglichkeiten eingeschränkt.
            Für typische Haushalte jedoch eine stabile Lösung.
          </p>
        </div>

        <!-- CONTENT -->
        <article class="prose prose-zinc max-w-none 
          prose-headings:uppercase prose-headings:tracking-tight prose-headings:font-bold
          prose-h2:text-[16px] prose-h2:border-b prose-h2:border-zinc-100 prose-h2:pb-2
          prose-p:text-[14px] prose-p:leading-relaxed prose-p:text-zinc-600
          prose-li:text-[14px] prose-li:text-zinc-600">
          <Content />
        </article>

      </div>
    </div>

    <!-- IMAGE -->
    <div class="mt-20 border-t border-zinc-100 pt-10">
      <h4 class="text-[10px] font-bold uppercase text-zinc-400 mb-6 tracking-widest">
        Produktansicht
      </h4>
      <img src={n.image} alt={n.title} class="max-w-md mx-auto block" />
    </div>

  </main>
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
  body { font-family: 'Inter', sans-serif; }
</style>