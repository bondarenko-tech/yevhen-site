---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { normalizeProduct } from "@lib/product-engine";

export async function getStaticPaths() {
  const p = await getCollection("produkte");
  return p.map(e => ({
    params: { kategorie: e.data.kategorie, produkt: e.slug }
  }));
}

const { kategorie, produkt } = Astro.params;
const entries = await getCollection("produkte");

const entry = entries.find(
  e => e.slug === produkt && e.data.kategorie === kategorie
);

if (!entry) throw new Error("Produkt-Datei nicht gefunden");

const { Content } = await entry.render();
const n = normalizeProduct(entry);

/* ───────── SEO ───────── */
const title = n.title;
const description = n.teaser;

/* ───────── Breadcrumb ───────── */
const breadcrumb = [
  { name: "Start", url: "/" },
  { name: "Empfehlungen", url: "/empfehlungen/" },
  { name: kategorie, url: `/empfehlungen/${kategorie}/` },
  { name: n.title, url: `/empfehlungen/${kategorie}/${produkt}/` }
];

/* ───────── PRODUCT SCHEMA (Affiliate-safe) ───────── */
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": n.title,
    "image": n.image,
    "description": n.teaser,
    "brand": {
      "@type": "Brand",
      "name": typeof n.brand === "string" ? n.brand : n.brand?.name
    },
    "offers": {
      "@type": "Offer",
      "url": n.linkExtern,
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    }
  }
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumb={breadcrumb}
  jsonLd={jsonLd}
  produkt={entry}
>

<main class="max-w-[1000px] mx-auto px-4 py-10">

  <!-- 🔥 HERO -->
  <header class="mb-10">
    <h1 class="text-2xl md:text-3xl font-black mb-4">
      {n.title}
    </h1>

    <p class="text-lg text-gray-600 max-w-2xl">
      {n.teaser}
    </p>
  </header>

  <!-- 🔥 GRID -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

    <!-- LEFT -->
    <div class="lg:col-span-4">

      <div class="sticky top-6 space-y-6">

        <img src={n.image} alt={n.title} class="rounded-xl shadow-md" />

        <!-- SPECS -->
        <div class="bg-white border rounded-xl p-4">
          <h2 class="font-bold mb-4 text-sm uppercase text-gray-500">
            Kurzfakten
          </h2>

          <ul class="space-y-2 text-sm">
            {n.kurzfakten?.map(k => (
              <li class="flex justify-between">
                <span class="text-gray-500">{k.label}</span>
                <strong>{k.value}</strong>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA -->
        <a
          href={n.linkExtern}
          target="_blank"
          class="block w-full bg-[#FF9900] hover:bg-black text-white text-center py-4 rounded-xl font-bold transition"
        >
          Preis bei Amazon prüfen →
        </a>

        <!-- TRUST -->
        <div class="text-xs text-gray-500">
          Hinweis: Partnerlink. Preis kann variieren.
        </div>

      </div>
    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8">

      <!-- CONTENT -->
      <article class="prose max-w-none">
        <Content />
      </article>

    </div>

  </div>

</main>

</BaseLayout>