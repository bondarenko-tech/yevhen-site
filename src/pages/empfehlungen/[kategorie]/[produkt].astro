---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { normalizeProduct } from "@lib/product-engine";

export async function getStaticPaths() {
  const p = await getCollection("produkte");

  return p
    .filter(e => {
      if (!e.slug) return false;
      if (!e.data) return false;
      if (!e.data.kategorie) return false;
      return true;
    })
    .map(e => ({
      params: {
        kategorie: e.data.kategorie,
        produkt: e.slug
      }
    }));
}

const { kategorie, produkt } = Astro.params;
const entries = await getCollection("produkte");

const entry = entries.find(
  e => e.slug === produkt && e.data.kategorie === kategorie
);

if (!entry) throw new Error("Produkt-Datei nicht gefunden");

const { Content } = await entry.render();
const n = normalizeProduct(entry);

/* 🔥 SEO (новый формат) */
const title = `${n.title} einfach erklärt: Einordnung, Vorteile und Alternativen`;
const description = `${n.title} verständlich eingeordnet: Funktionen, Vorteile, Nachteile und mögliche Alternativen im Überblick.`;

/* 🔥 NOINDEX для слабых страниц */
const isThin = !entry.body || entry.body.length < 800;

/* 🔗 RELATED */
const related = entries
  .filter(e => e.slug !== entry.slug && e.data.kategorie === entry.data.kategorie)
  .slice(0, 3);

/* Breadcrumb */
const breadcrumb = [
  { name: "Start", url: "/" },
  { name: "Empfehlungen", url: "/empfehlungen/" },
  { name: kategorie, url: `/empfehlungen/${kategorie}/` },
  { name: n.title, url: `/empfehlungen/${kategorie}/${produkt}/` }
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumb={breadcrumb}
  produkt={entry}
  robots={isThin ? "noindex, follow" : "index, follow"}
>



<main class="max-w-[900px] mx-auto px-4 py-10">

  <!-- HERO -->
  <section class="mb-8">

    <h1 class="text-2xl font-semibold mb-3">
      {n.title} einfach erklärt: Für wen ist dieses Gerät sinnvoll?
    </h1>

    <p class="text-neutral-600 mb-6">
      Auf dieser Seite finden Sie eine kompakte Einordnung zu diesem Gerät:
  Funktionen, typische Einsatzbereiche sowie Hinweise dazu, wann sich auch eine Alternative anbieten kann.
    </p>

    <div class="grid md:grid-cols-2 gap-6 items-start">

      <img 
        src={n.image} 
        alt={n.title} 
        class="rounded-xl w-full max-w-sm"
      />

      <div>

        {n.videoShortId && (
          <div class="aspect-video mb-4">
            <iframe
              class="w-full h-full rounded-xl"
              src={`https://www.youtube.com/embed/${n.videoShortId}`}
              allowfullscreen
            ></iframe>
          </div>
        )}

        {n.linkExtern && (
          <a
            href={n.linkExtern}
            target="_blank"
            class="inline-block bg-[#FF9900] text-white px-5 py-3 rounded-xl font-semibold"
          >
            Bei Amazon ansehen →
          </a>
        )}

      </div>

    </div>

  </section>

  <!-- 🧠 EINORDNUNG -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-3">
      Kurz eingeordnet
    </h2>

    <p class="text-neutral-700 mb-3">
  Dieses Gerät kann sinnvoll sein, wenn eine stabile WLAN-Abdeckung in mehreren Räumen benötigt wird
  oder typische Verbindungsprobleme im Alltag reduziert werden sollen.
</p>

<p class="text-neutral-700">
  In kleineren Wohnungen oder bei einfachen Anforderungen reicht häufig bereits eine günstigere Lösung aus.
</p>
  </section>

  <!-- ⚔️ PRO / CONTRA -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4">
      Vorteile und Nachteile
    </h2>

    <div class="grid md:grid-cols-2 gap-6 text-sm">

      <div>
        <strong>✔ Vorteile</strong>
        <ul class="mt-2 space-y-1">
          <li>Kann für eine stabile Verbindung sorgen</li>
          <li>Für größere Wohnbereiche besser geeignet</li>
          <li>In vielen Fällen einfach einzurichten</li>
        </ul>
      </div>

      <div>
        <strong>✖ Nachteile</strong>
        <ul class="mt-2 space-y-1">
          <li>Im Vergleich zu einfachen Lösungen oft teurer</li>
          <li>Für kleine Wohnungen nicht immer notwendig</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- ⚔️ VERGLEICH -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-3">
      Alternativen im Vergleich
    </h2>

    <p class="text-neutral-700">
      Im Vergleich zu einfachen Repeatern kann dieses Modell je nach Einsatzbereich mehr Stabilität und Komfort bieten,
      ist jedoch meist teurer. Wer vor allem auf den Preis achtet, findet oft günstigere Alternativen.
      Für größere Wohnungen oder komplexere Netzwerke kann dagegen auch ein Mesh-System sinnvoll sein.
    </p>
  </section>

  <!-- 📊 SPECS -->
  {n.kurzfakten && (
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-4">
        Technische Daten
      </h2>

      <div class="border rounded-xl divide-y">
        {n.kurzfakten.map(k => (
          <div class="flex justify-between px-4 py-2 text-sm">
            <span class="text-neutral-500">{k.label}</span>
            <span class="font-medium">{k.value}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- 📝 MAIN CONTENT -->
  <article class="prose prose-zinc max-w-none mb-12">
    <Content />
  </article>

  <!-- 🔗 RELATED -->
  {related.length > 0 && (
    <section class="mb-12">
      <h2 class="text-lg font-semibold mb-4">
        Weitere Empfehlungen
      </h2>

      <div class="grid md:grid-cols-3 gap-6">

        {related.map(r => {
          const p = normalizeProduct(r);

          return (
            <a
              href={`/empfehlungen/${p.kategorie}/${r.slug}/`}
              class="block border rounded-xl p-3 hover:shadow-sm"
            >
              <img src={p.image} alt={p.title} class="mb-2" />
              <h3 class="text-sm font-semibold">{p.title}</h3>
            </a>
          );
        })}

      </div>
    </section>
  )}

  <!-- DISCLAIMER -->
  <p class="text-xs text-neutral-500 text-center leading-relaxed">
  Hinweis: Diese Seite ist kein Online-Shop. Einige Verlinkungen sind Partnerlinks,
  zum Beispiel zu Amazon. Wenn über einen solchen Link ein Kauf erfolgt, kann eine Provision anfallen.
  Für Sie entstehen keine zusätzlichen Kosten.
</p>

</main>

</BaseLayout>