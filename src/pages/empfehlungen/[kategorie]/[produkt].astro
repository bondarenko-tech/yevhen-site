---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { normalizeProduct } from "@lib/product-engine";

export async function getStaticPaths() {
  const p = await getCollection("produkte");
  return p.map((e) => ({
    params: { kategorie: e.data.kategorie, produkt: e.slug }
  }));
}

const { kategorie, produkt } = Astro.params;
const entries = await getCollection("produkte");

const entry = entries.find(
  (e) => e.slug === produkt && e.data.kategorie === kategorie
);

if (!entry) throw new Error("Produkt-Datei nicht gefunden");

const related = entries
  .filter((e) => e.slug !== entry.slug)
  .map((e) => {
    const commonTags =
      e.data.tags?.filter((tag) => entry.data.tags?.includes(tag)) || [];

    return {
      entry: e,
      score: commonTags.length
    };
  })
  .filter((e) => e.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3);

const { Content } = await entry.render();
const n = normalizeProduct(entry);

const title = n.title;
const description = n.teaser ?? n.description ?? n.title;

const breadcrumb = [
  { name: "Start", url: "/" },
  { name: "Empfehlungen", url: "/empfehlungen/" },
  { name: kategorie, url: `/empfehlungen/${kategorie}/` },
  { name: n.title, url: `/empfehlungen/${kategorie}/${produkt}/` }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": n.title,
    "image": n.image,
    "description": description,
    "brand": {
      "@type": "Brand",
      "name": typeof n.brand === "string" ? n.brand : n.brand?.name
    },
    "offers": {
      "@type": "Offer",
      "url": n.linkExtern,
      "priceCurrency": n.priceCurrency || "EUR",
      "availability": "https://schema.org/InStock"
    }
  }
];

const displayPrice =
  typeof n.preis === "number"
    ? new Intl.NumberFormat("de-DE", {
        style: "currency",
        currency: n.priceCurrency || "EUR",
        minimumFractionDigits: 0,
        maximumFractionDigits: 2
      }).format(n.preis)
    : null;
---

<BaseLayout
  title={title}
  description={description}
  breadcrumb={breadcrumb}
  jsonLd={jsonLd}
  produkt={entry}
>
  <main class="max-w-[1120px] mx-auto px-4 py-8 pb-24">
    <!-- HERO -->
    <section class="mb-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- IMAGE -->
        <div class="lg:col-span-4">
          <div class="bg-white rounded-2xl border border-neutral-200 p-4">
            <img
              src={n.image}
              alt={n.title}
              class="w-full max-w-[360px] mx-auto rounded-xl"
            />
          </div>
        </div>

        <!-- MAIN INFO -->
        <div class="lg:col-span-5">
          <h1 class="text-2xl md:text-4xl font-semibold text-neutral-900 mb-4 leading-tight">
            {n.title}
          </h1>

          <p class="text-base md:text-lg text-neutral-600 leading-relaxed mb-5">
            {n.teaser}
          </p>

          <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-5 mb-5">
            <h2 class="text-sm font-semibold text-neutral-900 mb-2">
              Kurz erklärt
            </h2>
            <p class="text-sm text-neutral-700 leading-relaxed">
              {n.teaser}
            </p>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-2xl p-5 mb-5">
            <h2 class="text-sm font-semibold text-neutral-900 mb-3">
              Gut zu wissen
            </h2>
            <div class="space-y-2 text-sm text-neutral-700">
              <p>✔ Router und Kabelmodem in einem Gerät</p>
              <p>✔ Sinnvoll bei vielen Geräten gleichzeitig</p>
              <p>✔ Geeignet für Kabelanschluss</p>
            </div>
          </div>

          {n.videoShortId && (
            <div class="mb-5">
              <div class="aspect-video rounded-2xl overflow-hidden bg-neutral-100 border border-neutral-200">
                <iframe
                  class="w-full h-full"
                  src={`https://www.youtube.com/embed/${n.videoShortId}`}
                  title="YouTube video"
                  frameborder="0"
                  allowfullscreen
                ></iframe>
              </div>
            </div>
          )}

          {n.linkExtern && (
            <div class="lg:hidden">
              <a
                href={n.linkExtern}
                target="_blank"
                rel="nofollow sponsored noopener"
                class="inline-flex items-center justify-center bg-[#FF9900] hover:bg-black text-white px-6 py-3 rounded-xl text-sm font-semibold transition"
              >
                Preis & Details bei Amazon ansehen →
              </a>
            </div>
          )}
        </div>

        <!-- BUY BOX -->
        <aside class="lg:col-span-3">
          <div class="lg:sticky lg:top-24">
            <div class="bg-white border border-neutral-200 rounded-2xl p-5 shadow-sm">
              <div class="mb-5">
                <p class="text-xs uppercase tracking-wide text-neutral-500 mb-1">
                  Preis
                </p>
                <p class="text-3xl font-semibold text-neutral-900">
                  {displayPrice ?? "Preis siehe Amazon"}
                </p>
              </div>

              <div class="mb-5">
                <p class="text-xs uppercase tracking-wide text-neutral-500 mb-1">
                  Einordnung
                </p>
                <div class="flex items-center gap-2">
                  <span class="text-base">★★★★☆</span>
                  <span class="text-sm text-neutral-600">stark für Alltag & Zuhause</span>
                </div>
              </div>

              <div class="mb-5 space-y-2 text-sm text-neutral-700">
                <p>✔ Kabel + WLAN in einem Gerät</p>
                <p>✔ Für viele Geräte gleichzeitig</p>
                <p>✔ Gut für typische Heimnutzung</p>
              </div>

              {n.linkExtern && (
                <a
                  href={n.linkExtern}
                  target="_blank"
                  rel="nofollow sponsored noopener"
                  class="block text-center bg-[#FF9900] hover:bg-black text-white py-4 rounded-xl font-semibold transition"
                >
                  Bei Amazon ansehen →
                </a>
              )}

              <p class="text-[11px] text-neutral-500 leading-relaxed mt-3">
                Hinweis: Partnerlink. Preis und Verfügbarkeit können variieren.
              </p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- BODY -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <div class="lg:col-span-9">
        <!-- FÜR WEN -->
        <section class="mb-10">
          <h2 class="text-base font-semibold text-neutral-900 mb-4">
            Für wen geeignet
          </h2>

          <div class="border border-neutral-200 rounded-2xl p-5 bg-white text-sm text-neutral-700 leading-relaxed space-y-2">
            <p>✔ Sinnvoll für stabiles Internet im ganzen Zuhause</p>
            <p>✔ Geeignet für mehrere Geräte gleichzeitig</p>
            <p>✔ Gute Wahl bei schnellen Kabelanschlüssen</p>
            <p class="text-neutral-400 pt-2">
              Nicht ideal, wenn nur DSL oder VDSL vorhanden ist
            </p>
          </div>
        </section>

        <!-- SPECS -->
        {n.kurzfakten && (
          <section class="mb-10">
            <h2 class="text-base font-semibold text-neutral-900 mb-4">
              Technische Daten (vereinfacht)
            </h2>

            <div class="border border-neutral-200 rounded-2xl divide-y hover:shadow-sm transition bg-white overflow-hidden">
              {n.kurzfakten.map((k) => (
                <div class="flex justify-between gap-4 px-4 py-3 text-sm">
                  <span class="text-neutral-500">{k.label}</span>
                  <span class="text-neutral-900 font-medium text-right">{k.value}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- CONTENT -->
        <article
          class="prose prose-zinc max-w-none mb-12
          prose-h2:text-[28px]
          prose-h2:font-semibold
          prose-h2:mt-10
          prose-h2:mb-4
          prose-p:text-[18px]
          prose-p:leading-relaxed
          prose-li:text-[17px]
          prose-li:leading-relaxed"
        >
          <Content />
        </article>

        <!-- FAQ -->
        <section class="mb-12">
          <h2 class="text-base font-semibold text-neutral-900 mb-4">
            Häufige Fragen
          </h2>

          <div class="space-y-5 text-sm text-neutral-700">
            <div>
              <strong>Ist dieses Gerät für große Wohnungen geeignet?</strong>
              <p class="text-neutral-600 mt-1">
                Ja, besonders wenn viele Geräte gleichzeitig verbunden sind.
              </p>
            </div>

            <div>
              <strong>Funktioniert es mit Glasfaser?</strong>
              <p class="text-neutral-600 mt-1">
                Nein. Dieses Modell ist für Kabelanschlüsse gedacht, nicht für DSL oder Glasfaser direkt.
              </p>
            </div>
          </div>
        </section>

        <!-- ALTERNATIVEN -->
        <section class="mb-12">
          <h2 class="text-base font-semibold text-neutral-900 mb-4">
            Alternative Optionen
          </h2>

          <div class="border border-neutral-200 rounded-2xl p-5 text-sm text-neutral-700 space-y-2 bg-white">
            <p>Je nach Anschluss oder Wohnsituation können auch andere Lösungen sinnvoll sein:</p>

            <ul class="list-disc pl-5 space-y-1">
              <li>FRITZ!Box für DSL — wenn kein Kabelanschluss vorhanden ist</li>
              <li>Mesh-System — wenn das WLAN in mehrere Räume verteilt werden soll</li>
              <li>WLAN-Repeater — für einzelne problematische Bereiche</li>
            </ul>
          </div>
        </section>

        <!-- ÄHNLICHE PRODUKTE -->
        {related.length > 0 && (
          <section class="mb-12">
            <h2 class="text-base font-semibold text-neutral-900 mb-4">
              Ähnliche Produkte
            </h2>

            <div class="grid md:grid-cols-3 gap-6">
              {related.map((r) => {
                const p = normalizeProduct(r.entry);

                return (
                  <a
                    href={`/empfehlungen/${p.kategorie}/${r.entry.slug}/`}
                    class="block border border-neutral-200 rounded-2xl overflow-hidden hover:shadow-sm transition bg-white"
                  >
                    <div class="aspect-video bg-neutral-100 flex items-center justify-center">
                      {p.image ? (
                        <img src={p.image} alt={p.title} class="object-contain max-h-full" />
                      ) : (
                        <span class="text-neutral-400 text-sm">Kein Bild</span>
                      )}
                    </div>

                    <div class="p-3">
                      <h3 class="text-sm font-semibold text-neutral-900 line-clamp-2">
                        {p.title}
                      </h3>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        )}

        <p class="text-xs text-neutral-500">
          Hinweis: Partnerlink. Preis und Verfügbarkeit können variieren.
        </p>
      </div>
    </section>

    <!-- MOBILE STICKY CTA -->
    {n.linkExtern && (
      <div class="fixed bottom-0 left-0 right-0 z-50 bg-white border-t shadow-sm p-3 md:hidden">
        <div class="flex items-center justify-between gap-3">
          <div class="min-w-0">
            <p class="text-xs text-neutral-500 truncate">{n.brand?.name}</p>
            <p class="text-sm font-semibold text-neutral-900 truncate">{n.title}</p>
            {displayPrice && (
              <p class="text-sm font-bold text-neutral-900">{displayPrice}</p>
            )}
          </div>

          <a
            href={n.linkExtern}
            target="_blank"
            rel="nofollow sponsored noopener"
            class="shrink-0 bg-[#FF9900] text-white px-4 py-3 rounded-xl text-sm font-semibold whitespace-nowrap"
          >
            Bei Amazon →
          </a>
        </div>
      </div>
    )}
  </main>
</BaseLayout>