---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { normalizeProduct } from "@lib/product-engine";

export async function getStaticPaths() {
  const p = await getCollection("produkte");
  return p.map(e => ({
    params: { kategorie: e.data.kategorie, produkt: e.slug }
  }));
}

const { kategorie, produkt } = Astro.params;
const entries = await getCollection("produkte");

/* ✅ СНАЧАЛА НАХОДИМ ТЕКУЩИЙ ПРОДУКТ */
const entry = entries.find(
  e => e.slug === produkt && e.data.kategorie === kategorie
);

if (!entry) throw new Error("Produkt-Datei nicht gefunden");

/* ✅ ПОТОМ СЧИТАЕМ ПОХОЖИЕ */
const related = entries
  .filter(e => e.slug !== entry.slug)
  .map(e => {
    const commonTags = e.data.tags?.filter(tag =>
      entry.data.tags?.includes(tag)
    ) || [];

    return {
      entry: e,
      score: commonTags.length
    };
  })
  .filter(e => e.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3);

const { Content } = await entry.render();
const n = normalizeProduct(entry);

/* SEO */
const title = n.title;
const description = n.teaser;

/* Breadcrumb */
const breadcrumb = [
  { name: "Start", url: "/" },
  { name: "Empfehlungen", url: "/empfehlungen/" },
  { name: kategorie, url: `/empfehlungen/${kategorie}/` },
  { name: n.title, url: `/empfehlungen/${kategorie}/${produkt}/` }
];

/* JSON-LD */
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": n.title,
    "image": n.image,
    "description": n.teaser,
    "brand": {
      "@type": "Brand",
      "name": typeof n.brand === "string" ? n.brand : n.brand?.name
    },
    "offers": {
      "@type": "Offer",
      "url": n.linkExtern,
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    }
  }
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumb={breadcrumb}
  jsonLd={jsonLd}
  produkt={entry}
>

<main class="max-w-[920px] mx-auto px-4 py-10">

  <!-- HERO GRID -->
<section class="mb-10">

  <div class="grid md:grid-cols-2 gap-8 items-start">

    <!-- LEFT: IMAGE -->
    <div>
      <img 
        src={n.image} 
        alt={n.title} 
        class="w-full max-w-sm rounded-xl"
      />
    </div>

    <!-- RIGHT: TEXT -->
    <div>

      <h1 class="text-xl md:text-2xl font-semibold text-neutral-900 mb-3 leading-snug">
        {n.title}
      </h1>

      <p class="text-sm text-neutral-600 leading-relaxed mb-4">
        {n.teaser}
      </p>

      <!-- VIDEO -->
      {n.videoShortId && (
        <div class="mb-4">
          <div class="aspect-video rounded-xl overflow-hidden">
            <iframe
              class="w-full h-full"
              src={`https://www.youtube.com/embed/${n.videoShortId}`}
              title="YouTube video"
              frameborder="0"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      )}

      <!-- CTA -->
      {n.linkExtern && (
        <a
          href={n.linkExtern}
          target="_blank"
          class="inline-block bg-[#FF9900] hover:bg-black text-white px-6 py-3 rounded-xl text-sm font-semibold transition"
        >
          Bei Amazon ansehen →
        </a>
      )}

    </div>

  </div>

</section>

  <!-- KURZ ERKLÄRT -->
  <section class="mb-10">
    <div class="bg-neutral-50 border border-neutral-200 rounded-xl p-5">
      <h2 class="text-sm font-semibold text-neutral-900 mb-2">
        Kurz erklärt
      </h2>

      <p class="text-sm text-neutral-600 leading-relaxed">
        {n.teaser}
      </p>
    </div>
  </section>

  <!-- FÜR WEN -->
  <section class="mb-10">
    <h2 class="text-sm font-semibold text-neutral-900 mb-4">
      Für wen geeignet
    </h2>

    <div class="border rounded-xl p-4 text-sm text-neutral-700 leading-relaxed space-y-2">
      <p>✔ Sinnvoll für stabiles WLAN im ganzen Zuhause</p>
      <p>✔ Geeignet für mehrere Geräte gleichzeitig</p>
      <p>✔ Gute Wahl bei schnellen Internetanschlüssen</p>

      <p class="text-neutral-400 pt-2">
        Nicht ideal für sehr kleine Wohnungen oder einfache Nutzung
      </p>
    </div>
  </section>

  <!-- SPECS -->
  {n.kurzfakten && (
    <section class="mb-10">
      <h2 class="text-sm font-semibold text-neutral-900 mb-4">
        Technische Daten (vereinfacht)
      </h2>

      <div class="border rounded-xl divide-y hover:shadow-sm transition">
        {n.kurzfakten.map(k => (
          <div class="flex justify-between px-4 py-3 text-sm">
            <span class="text-neutral-500">{k.label}</span>
            <span class="text-neutral-900 font-medium">{k.value}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- CONTENT -->
  <article class="prose prose-zinc max-w-none mb-12
    prose-h2:text-base
    prose-h2:font-semibold
    prose-h2:mt-8
    prose-p:text-[15px]
    prose-p:leading-relaxed
    prose-li:text-[15px]
  ">
    <Content />
  </article>

  <!-- FAQ -->
  <section class="mb-12">
    <h2 class="text-sm font-semibold text-neutral-900 mb-4">
      Häufige Fragen
    </h2>

    <div class="space-y-4 text-sm text-neutral-700">
      <div>
        <strong>Ist dieses Gerät für große Wohnungen geeignet?</strong>
        <p class="text-neutral-600">
          Ja, besonders bei mehreren Räumen oder Etagen.
        </p>
      </div>

      <div>
        <strong>Funktioniert es mit Glasfaser?</strong>
        <p class="text-neutral-600">
          Ja, vor allem bei schnellen Anschlüssen sinnvoll.
        </p>
      </div>
    </div>
  </section>

  <!-- ALTERNATIVEN -->
  <section class="mb-12">
    <h2 class="text-sm font-semibold text-neutral-900 mb-4">
      Alternative Optionen
    </h2>

    <div class="border rounded-xl p-4 text-sm text-neutral-700 space-y-2">
      <p>
        Je nach Wohnung können auch einfachere Lösungen sinnvoll sein:
      </p>

      <ul class="list-disc pl-5 space-y-1">
        <li>WLAN-Repeater – für einzelne Räume</li>
        <li>Kleines Mesh-System – für mittlere Wohnungen</li>
        <li>Powerline – bei dicken Wänden</li>
      </ul>
    </div>
  </section>

  <!-- ÄHNLICHE PRODUKTE -->
  {related.length > 0 && (
    <section class="mb-12">
      <h2 class="text-sm font-semibold text-neutral-900 mb-4">
        Ähnliche Produkte
      </h2>

      <div class="grid md:grid-cols-3 gap-6">

        {related.map(r => {
          const p = normalizeProduct(r.entry);

          return (
            <a
              href={`/empfehlungen/${p.kategorie}/${r.entry.slug}/`}
              class="block border rounded-xl overflow-hidden hover:shadow-sm transition bg-white"
            >
              <div class="aspect-video bg-neutral-100 flex items-center justify-center">
                {p.image ? (
                  <img src={p.image} alt={p.title} class="object-contain max-h-full" />
                ) : (
                  <span class="text-neutral-400 text-sm">Kein Bild</span>
                )}
              </div>

              <div class="p-3">
                <h3 class="text-sm font-semibold text-neutral-900 line-clamp-2">
                  {p.title}
                </h3>
              </div>
            </a>
          );
        })}

      </div>
    </section>
  )}

  <!-- DISCLAIMER -->
  <p class="text-xs text-neutral-500 text-center">
    Hinweis: Partnerlink. Preis und Verfügbarkeit können variieren.
  </p>

</main>

</BaseLayout>