---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { normalizeProduct } from "@lib/product-engine";

const SITE =
  Astro.site?.toString().replace(/\/$/, "") ??
  "https://yevhenbondarenko.com";

export async function getStaticPaths() {
  const p = await getCollection("produkte");

  return p
    .filter((e) => {
      if (!e.slug) return false;
      if (!e.data) return false;
      if (!e.data.kategorie) return false;
      return true;
    })
    .map((e) => ({
      params: {
        kategorie: e.data.kategorie,
        produkt: e.slug
      }
    }));
}

const { kategorie, produkt } = Astro.params;
const entries = await getCollection("produkte");

const entry = entries.find(
  (e) => e.slug === produkt && e.data.kategorie === kategorie
);

if (!entry) throw new Error("Produkt-Datei nicht gefunden");

const { Content } = await entry.render();
const n = normalizeProduct(entry);

const title = `${n.title} einfach erklärt: Einordnung, Vorteile und Alternativen`;
const description = `${n.title} verständlich eingeordnet: Funktionen, Vorteile, Nachteile und mögliche Alternativen im Überblick.`;

const canonical = `${SITE}/empfehlungen/${kategorie}/${produkt}/`;

const related = entries
  .filter((e) => e.slug !== entry.slug && e.data.kategorie === entry.data.kategorie)
  .slice(0, 3);

const breadcrumb = [
  { name: "Start", url: "/" },
  { name: "Empfehlungen", url: "/empfehlungen/" },
  { name: kategorie, url: `/empfehlungen/${kategorie}/` },
  { name: n.title, url: `/empfehlungen/${kategorie}/${produkt}/` }
];

const categoryLabelMap = {
  sicherheit: "Sicherheit & Überwachung",
  "smart-home": "Smart Home",
  strom: "Strom & Steckdosen",
  klima: "Klima & Ventilatoren",
  beleuchtung: "Beleuchtung",
  netzwerk: "Netzwerk",
  sonstiges: "Technik & Sonstiges"
};

const categoryLabel =
  categoryLabelMap[kategorie as keyof typeof categoryLabelMap] ?? "Technik";

const compareHref =
  kategorie === "sicherheit"
    ? "/vergleiche/ring-innenkamera-vs-pan-tilt/"
    : `/empfehlungen/${kategorie}/`;

const compareLabel =
  kategorie === "sicherheit"
    ? "Erst vergleichen"
    : "Ähnliche Produkte ansehen";

const affiliateHint =
  "Hinweis: Einige Verlinkungen sind Partnerlinks. Wenn über einen solchen Link ein Kauf erfolgt, kann eine Provision anfallen. Für Sie entstehen keine zusätzlichen Kosten.";

const shortDescription =
  n.description ||
  `${n.title} ist vor allem dann interessant, wenn eine alltagstaugliche Lösung in der Kategorie ${categoryLabel} gesucht wird.`;

const useCases =
  kategorie === "sicherheit"
    ? [
        "Für Wohnungen, Flur, Wohnzimmer oder einzelne wichtige Bereiche",
        "Für Nutzer, die per App schnell nachsehen möchten",
        "Für Menschen, die mehr Sicherheit oder Kontrolle im Alltag suchen",
        "Für alle, die eine verständliche Lösung ohne unnötige Komplexität wollen"
      ]
    : [
        "Für Nutzer, die eine einfache und verständliche Lösung suchen",
        "Für Haushalte, in denen das Gerät regelmäßig im Alltag genutzt wird",
        "Für alle, die Wert auf ein gutes Verhältnis aus Preis, Nutzen und Bedienung legen",
        "Für Menschen, die lieber klare Funktionen statt unnötiger Komplexität wollen"
      ];

const notIdeal =
  kategorie === "sicherheit"
    ? [
        "wenn ganz spezielle Profi-Funktionen erwartet werden",
        "wenn nur der niedrigste Preis zählt",
        "wenn bereits eine passende Lösung vorhanden ist",
        "wenn der konkrete Einsatzbereich gar nicht zu diesem Modell passt"
      ]
    : [
        "wenn nur das günstigste Modell gesucht wird",
        "wenn sehr spezielle Anforderungen erfüllt werden sollen",
        "wenn bereits eine passende Lösung vorhanden ist",
        "wenn deutlich mehr Leistung oder Spezialfunktionen nötig sind"
      ];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumb={breadcrumb}
  produkt={entry}
  robots="index, follow"
>
  <main class="max-w-[980px] mx-auto px-4 py-10">
    <!-- HERO -->
    <section class="mb-10">
      <div class="max-w-3xl mb-6">
        <h1 class="text-2xl md:text-3xl font-semibold tracking-tight mb-3">
          {n.title} einfach erklärt: Für wen ist dieses Gerät sinnvoll?
        </h1>

        <p class="text-neutral-600 leading-relaxed">
          Auf dieser Seite finden Sie eine kompakte Einordnung zu diesem Gerät:
          typische Einsatzbereiche, wichtige Funktionen sowie Hinweise dazu,
          wann sich dieses Modell lohnt – und wann eher eine Alternative sinnvoll ist.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div class="bg-white border rounded-2xl p-4">
          <img
            src={n.image}
            alt={n.title}
            class="rounded-xl w-full max-w-md mx-auto"
            loading="eager"
          />
        </div>

        <div class="space-y-5">
          {n.videoShortId && (
            <div>
              <p class="text-sm font-semibold text-neutral-800 mb-2">
                Kurz erklärt im Video
              </p>
              <div class="aspect-video">
                <iframe
                  class="w-full h-full rounded-2xl border"
                  src={`https://www.youtube.com/embed/${n.videoShortId}`}
                  title={`${n.title} Video`}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                ></iframe>
              </div>
            </div>
          )}

          <div class="border rounded-2xl p-5 bg-white">
            <h2 class="text-base font-semibold mb-3">
              Kurzfazit
            </h2>

            <p class="text-sm text-neutral-700 leading-relaxed mb-4">
              {shortDescription}
            </p>

            <div class="rounded-xl bg-neutral-50 border border-neutral-200 p-4 mb-4">
              <p class="text-sm font-medium text-neutral-900 mb-2">
                Wann lohnt sich dieses Modell?
              </p>
              <ul class="space-y-1 text-sm text-neutral-700">
                <li>• wenn die wichtigsten Funktionen zum eigenen Alltag passen</li>
                <li>• wenn eine unkomplizierte und verständliche Lösung gesucht wird</li>
                <li>• wenn Preis, Nutzen und Einsatzbereich zueinander passen</li>
              </ul>
            </div>

            <div class="flex flex-wrap gap-3">
              {n.linkExtern && (
                <a
                  href={n.linkExtern}
                  target="_blank"
                  rel="nofollow sponsored noopener noreferrer"
                  class="inline-flex items-center justify-center bg-[#FF9900] text-white px-5 py-3 rounded-xl font-semibold hover:opacity-90 transition"
                >
                  Bei Amazon ansehen →
                </a>
              )}

              <a
                href={compareHref}
                class="inline-flex items-center justify-center border border-neutral-200 px-5 py-3 rounded-xl font-semibold text-neutral-800 hover:bg-neutral-50 transition"
              >
                {compareLabel}
              </a>
            </div>

            <p class="text-xs text-neutral-500 mt-4 leading-relaxed">
              {affiliateHint}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FÜR WEN / EHER NICHT -->
    <section class="mb-10">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="border rounded-2xl p-5 bg-white">
          <h2 class="text-lg font-semibold mb-3">
            Für wen sinnvoll?
          </h2>

          <ul class="space-y-2 text-sm text-neutral-700">
            {useCases.map((item) => <li>• {item}</li>)}
          </ul>
        </div>

        <div class="border rounded-2xl p-5 bg-white">
          <h2 class="text-lg font-semibold mb-3">
            Eher nicht ideal, wenn …
          </h2>

          <ul class="space-y-2 text-sm text-neutral-700">
            {notIdeal.map((item) => <li>• {item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <!-- EINORDNUNG -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-3">
        Kurz eingeordnet
      </h2>

      <div class="bg-white border rounded-2xl p-5">
        <p class="text-neutral-700 mb-3 leading-relaxed">
          {n.title} gehört in die Kategorie <strong>{categoryLabel}</strong> und richtet
          sich an Nutzer, die eine praxistaugliche Lösung für den Alltag suchen.
          Entscheidend ist dabei weniger das Datenblatt allein, sondern ob das Gerät
          zum eigenen Einsatzbereich passt.
        </p>

        <p class="text-neutral-700 leading-relaxed">
          Wer vor allem Wert auf einfache Nutzung, nachvollziehbare Funktionen und
          eine schnelle Einordnung legt, ist hier richtig. Wer dagegen deutlich
          andere Anforderungen hat, sollte vor dem Kauf ähnliche Produkte oder
          einen passenden Vergleich ansehen.
        </p>

        <div class="mt-4">
          <a
            href={compareHref}
            class="text-sm font-semibold text-blue-600 hover:underline"
          >
            → {compareLabel}
          </a>
        </div>
      </div>
    </section>

    <!-- PRO / CONTRA -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-4">
        Vorteile und Nachteile
      </h2>

      <div class="grid md:grid-cols-2 gap-6 text-sm">
        <div class="border rounded-2xl p-5 bg-white">
          <strong class="text-neutral-900">✔ Vorteile</strong>
          <ul class="mt-3 space-y-2 text-neutral-700">
            <li>Einfacher Einstieg ohne unnötig komplizierte Einrichtung</li>
            <li>Klare Ausrichtung auf typische Alltagsnutzung</li>
            <li>Interessant, wenn Preis und Nutzen in einem vernünftigen Verhältnis bleiben</li>
            <li>Für viele Nutzer schneller verständlich als technisch überladene Alternativen</li>
          </ul>
        </div>

        <div class="border rounded-2xl p-5 bg-white">
          <strong class="text-neutral-900">✖ Nachteile</strong>
          <ul class="mt-3 space-y-2 text-neutral-700">
            <li>Nicht automatisch die beste Wahl für jeden Spezialfall</li>
            <li>Je nach Anspruch können Zusatzfunktionen fehlen</li>
            <li>Bei sehr einfachen Anforderungen kann auch ein günstigeres Modell reichen</li>
            <li>Der Mehrwert zeigt sich vor allem dann, wenn das Gerät passend eingesetzt wird</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ALTERNATIVEN -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-3">
        Alternativen im Vergleich
      </h2>

      <div class="bg-white border rounded-2xl p-5">
        <p class="text-neutral-700 leading-relaxed">
          Nicht jedes Modell ist automatisch die beste Lösung für jeden Haushalt.
          Je nach Budget, Einsatzbereich und gewünschtem Funktionsumfang kann auch
          eine einfachere oder spezialisiertere Alternative sinnvoller sein.
        </p>

        <div class="mt-4 flex flex-col gap-2 text-sm">
          <a href={compareHref} class="text-blue-600 font-semibold hover:underline">
            → {compareLabel}
          </a>
          <a href={`/empfehlungen/${kategorie}/`} class="text-blue-600 font-semibold hover:underline">
            → Weitere Geräte dieser Kategorie
          </a>
          <a href="/vergleiche/" class="text-blue-600 font-semibold hover:underline">
            → Alle Vergleiche ansehen
          </a>
        </div>
      </div>
    </section>

    <!-- SPECS -->
    {n.kurzfakten && n.kurzfakten.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-semibold mb-4">
          Technische Daten
        </h2>

        <div class="border rounded-2xl divide-y bg-white overflow-hidden">
          {n.kurzfakten.map((k) => (
            <div class="flex justify-between gap-4 px-4 py-3 text-sm">
              <span class="text-neutral-500">{k.label}</span>
              <span class="font-medium text-right">{k.value}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- CONTENT -->
    <article class="prose prose-zinc max-w-none mb-12">
      <Content />
    </article>

    <!-- CTA NACH CONTENT -->
    <section class="mb-12">
      <div class="border rounded-2xl p-6 bg-neutral-50">
        <h2 class="text-lg font-semibold mb-3">
          Noch unsicher?
        </h2>

        <p class="text-neutral-700 text-sm leading-relaxed mb-4">
          Wenn Sie noch nicht sicher sind, ob dieses Modell wirklich zu Ihrem
          Zuhause oder Alltag passt, lohnt sich vor dem Kauf ein schneller Blick
          auf ähnliche Produkte oder einen passenden Vergleich.
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href={compareHref}
            class="inline-flex items-center justify-center bg-neutral-900 text-white px-5 py-3 rounded-xl font-semibold hover:bg-blue-600 transition"
          >
            {compareLabel}
          </a>

          <a
            href={`/empfehlungen/${kategorie}/`}
            class="inline-flex items-center justify-center border border-neutral-200 px-5 py-3 rounded-xl font-semibold text-neutral-800 hover:bg-white transition"
          >
            Weitere Empfehlungen
          </a>
        </div>
      </div>
    </section>

    <!-- RELATED -->
    {related.length > 0 && (
      <section class="mb-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold">
            Weitere Empfehlungen
          </h2>

          <a
            href={`/empfehlungen/${kategorie}/`}
            class="text-sm text-blue-600 hover:underline"
          >
            Alle anzeigen →
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {related.map((r) => {
            const p = normalizeProduct(r);

            return (
              <a
                href={`/empfehlungen/${p.kategorie}/${r.slug}/`}
                class="block border rounded-2xl p-4 hover:shadow-sm transition bg-white"
              >
                <img
                  src={p.image}
                  alt={p.title}
                  class="mb-3 rounded-xl"
                  loading="lazy"
                />
                <h3 class="text-sm font-semibold text-neutral-900">
                  {p.title}
                </h3>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </main>
</BaseLayout>