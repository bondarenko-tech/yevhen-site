---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { normalizeProduct } from "@lib/product-engine";

export async function getStaticPaths() {
  const p = await getCollection("produkte");
  return p.map(e => ({
    params: { kategorie: e.data.kategorie, produkt: e.slug }
  }));
}

const { kategorie, produkt } = Astro.params;
const entries = await getCollection("produkte");

const entry = entries.find(
  e => e.slug === produkt && e.data.kategorie === kategorie
);

if (!entry) throw new Error("Produkt-Datei nicht gefunden");

const { Content } = await entry.render();
const n = normalizeProduct(entry);

/* SEO */
const title = n.title;
const description = n.teaser;

/* Breadcrumb */
const breadcrumb = [
  { name: "Start", url: "/" },
  { name: "Empfehlungen", url: "/empfehlungen/" },
  { name: kategorie, url: `/empfehlungen/${kategorie}/` },
  { name: n.title, url: `/empfehlungen/${kategorie}/${produkt}/` }
];

/* Schema */
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": n.title,
    "image": n.image,
    "description": n.teaser,
    "brand": {
      "@type": "Brand",
      "name": typeof n.brand === "string" ? n.brand : n.brand?.name
    },
    "offers": {
      "@type": "Offer",
      "url": n.linkExtern,
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    }
  }
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumb={breadcrumb}
  jsonLd={jsonLd}
  produkt={entry}
>

<main class="max-w-[920px] mx-auto px-4 py-10">

  <!-- HERO -->
  <header class="mb-10">
    <h1 class="text-2xl md:text-3xl font-semibold text-zinc-900 mb-4">
      {n.title}
    </h1>

    <p class="text-base text-zinc-600 max-w-xl leading-relaxed">
      {n.teaser}
    </p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

    <!-- LEFT -->
    <div class="lg:col-span-4">

      <div class="sticky top-6 space-y-5">

        <img src={n.image} alt={n.title} class="rounded-lg shadow-sm" />

        <!-- SPECS -->
        <div class="bg-white border border-zinc-200 rounded-lg p-4">
          <h2 class="text-xs uppercase tracking-wide text-zinc-400 mb-3">
            Kurzfakten
          </h2>

          <ul class="space-y-2 text-sm">
            {n.kurzfakten?.map(k => (
              <li class="flex justify-between">
                <span class="text-zinc-500">{k.label}</span>
                <span class="text-zinc-900 font-medium">{k.value}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA -->
        <a
          href={n.linkExtern}
          target="_blank"
          class="block w-full bg-[#FF9900] hover:bg-[#e68a00] text-white text-center py-3 rounded-lg text-sm font-medium transition"
        >
          Bei Amazon ansehen →
        </a>

        <div class="text-xs text-zinc-400">
          Partnerlink · Preis kann variieren
        </div>

      </div>
    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8">

      <!-- INFO BLOCK -->
      <div class="mb-8 p-4 bg-zinc-50 border border-zinc-200 rounded-lg text-sm text-zinc-600">
        <strong class="block mb-1 text-zinc-700">Gut zu wissen</strong>
        Dieses Gerät ist ideal für stabile WLAN-Verbindungen im Alltag.
        Für sehr spezielle Profi-Setups ist es weniger gedacht.
      </div>

      <!-- CONTENT -->
      <article class="prose prose-zinc max-w-none 
        prose-h2:font-semibold 
        prose-h2:text-lg 
        prose-p:text-zinc-600 
        prose-strong:text-zinc-900">

        <Content />

      </article>

    </div>

  </div>

</main>

</BaseLayout>