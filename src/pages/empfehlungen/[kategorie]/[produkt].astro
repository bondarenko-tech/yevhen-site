---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { normalizeProduct } from "@lib/product-engine";

export async function getStaticPaths() {
  const p = await getCollection("produkte");
  return p.map(e => ({
    params: { kategorie: e.data.kategorie, produkt: e.slug }
  }));
}

const { kategorie, produkt } = Astro.params;
const entries = await getCollection("produkte");

const entry = entries.find(
  e => e.slug === produkt && e.data.kategorie === kategorie
);

if (!entry) throw new Error("Produkt-Datei nicht gefunden");

const { Content } = await entry.render();
const n = normalizeProduct(entry);

/* SEO */
const title = n.title;
const description = n.teaser;

/* Breadcrumb */
const breadcrumb = [
  { name: "Start", url: "/" },
  { name: "Empfehlungen", url: "/empfehlungen/" },
  { name: kategorie, url: `/empfehlungen/${kategorie}/` },
  { name: n.title, url: `/empfehlungen/${kategorie}/${produkt}/` }
];

/* JSON-LD */
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": n.title,
    "image": n.image,
    "description": n.teaser,
    "brand": {
      "@type": "Brand",
      "name": typeof n.brand === "string" ? n.brand : n.brand?.name
    },
    "offers": {
      "@type": "Offer",
      "url": n.linkExtern,
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock"
    }
  }
];
---

<BaseLayout
  title={title}
  description={description}
  breadcrumb={breadcrumb}
  jsonLd={jsonLd}
  produkt={entry}
>

<main class="max-w-[920px] mx-auto px-4 py-10">

  <!-- 🔥 TITLE -->
  <header class="mb-8">
    <h1 class="text-2xl md:text-3xl font-semibold text-neutral-900 mb-4 leading-snug">
      {n.title}
    </h1>

    <p class="text-base text-neutral-600 max-w-2xl leading-relaxed">
      {n.teaser}
    </p>
  </header>

  <!-- 🔥 IMAGE -->
  <div class="mb-10">
    <img 
      src={n.image} 
      alt={n.title} 
      class="w-full max-w-md mx-auto rounded-xl"
    />
  </div>

  <!-- 🔥 EINORDNUNG -->
  <section class="mb-10">
    <div class="bg-neutral-50 border border-neutral-200 rounded-xl p-5">
      <h2 class="text-sm font-semibold text-neutral-900 mb-2">
        Kurz erklärt
      </h2>

      <p class="text-sm text-neutral-600 leading-relaxed">
        Dieses Gerät ist für typische Alltagsnutzung gedacht.
        Es hilft dabei, die Funktion zu erfüllen, ohne dass man sich
        mit vielen technischen Details beschäftigen muss.
      </p>
    </div>
  </section>

  <!-- 🔥 SPECS -->
  {n.kurzfakten && (
    <section class="mb-10">
      <h2 class="text-sm font-semibold text-neutral-900 mb-4">
        Technische Daten (vereinfacht)
      </h2>

      <div class="border rounded-xl divide-y">
        {n.kurzfakten.map(k => (
          <div class="flex justify-between px-4 py-3 text-sm">
            <span class="text-neutral-500">{k.label}</span>
            <span class="text-neutral-900 font-medium">{k.value}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- 🔥 CONTENT -->
  <article class="prose prose-zinc max-w-none mb-12
    prose-h2:text-base
    prose-h2:font-semibold
    prose-h2:mt-8
    prose-p:text-[15px]
    prose-p:leading-relaxed
    prose-li:text-[15px]
  ">
    <Content />
  </article>

  <!-- 🔥 CTA -->
  {n.linkExtern && (
    <div class="mb-6">
      <a
        href={n.linkExtern}
        target="_blank"
        class="block text-center bg-[#FF9900] hover:bg-black text-white py-4 rounded-xl font-semibold transition"
      >
        Preis bei Amazon ansehen →
      </a>
    </div>
  )}

  <!-- 🔥 DISCLAIMER -->
  <p class="text-xs text-neutral-500 text-center">
    Hinweis: Partnerlink. Preis und Verfügbarkeit können variieren.
  </p>

</main>

</BaseLayout>