---
export const prerender = true;

import {
  getDynamicUsageText,
  getDynamicDecisionText,
  getDynamicCategoryText
} from "@lib/dynamic-text";
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { normalizeProduct } from "@lib/product-engine";
import { Image } from "astro:assets";
import YouTubeLite from "@components/YouTubeLite.astro";

const SITE =
  Astro.site?.toString().replace(/\/$/, "") ??
  "https://yevhenbondarenko.com";

export async function getStaticPaths() {
  const entries = await getCollection("produkte");

  return entries
    .filter((e) => e.slug && e.data?.kategorie)
    .map((e) => ({
      params: {
        kategorie: e.data.kategorie,
        produkt: e.slug
      }
    }));
}

const kategorie = Astro.params.kategorie ?? "";
const produkt = Astro.params.produkt ?? "";
const entries = await getCollection("produkte");

const entry = entries.find(
  (e) => e.slug === produkt && e.data.kategorie === kategorie
);

if (!entry) throw new Error("Produkt-Datei nicht gefunden");

const { Content } = await entry.render();
const n = normalizeProduct(entry);

const usageText = getDynamicUsageText(n.title, kategorie);
const decisionText = getDynamicDecisionText(n.title, n.preis);
const categoryText = getDynamicCategoryText(n.title, kategorie, n.preis);

const hasStringImage = typeof n.image === "string" && n.image.length > 0;
const hasAssetImage = !!n.image && typeof n.image !== "string";

const categoryLabelMap = {
  sicherheit: "Sicherheit & Überwachung",
  "smart-home": "Smart Home",
  strom: "Strom & Steckdosen",
  klima: "Klima & Luft",
  beleuchtung: "Beleuchtung",
  netzwerk: "WLAN & Netzwerk",
  sonstiges: "Technik & Sonstiges"
};

const categoryLabel =
  categoryLabelMap[kategorie as keyof typeof categoryLabelMap] ?? "Technik";

const title = `${n.title}: Lohnt sich das Modell wirklich?`;
const description =
  n.description?.slice(0, 155) ||
  `${n.title} verständlich erklärt: Einsatzbereiche und Alternativen im Überblick.`;

const canonical = `${SITE}/empfehlungen/${kategorie}/${produkt}/`;

/* 🔥 SEO FIX: Vergleich-Links */
const compareMap: Record<string, { href: string; label: string }> = {
  saugroboter: {
    href: "/vergleiche/saugroboter-vergleich-2026/",
    label: "Saugroboter Vergleich 2026 ansehen"
  },
  kamera: {
    href: "/vergleiche/ueberwachungskameras-2026/",
    label: "Überwachungskameras vergleichen"
  }
};

const productTyp = String(n.typ ?? "");

const compareData = compareMap[productTyp] ?? {
  href: `/empfehlungen/${kategorie}/`,
  label: "Ähnliche Produkte ansehen"
};

const compareHref = compareData.href;
const compareLabel = compareData.label;

const shortDescription =
  n.description ||
  `${n.title} ist eine praktische Lösung im Bereich ${categoryLabel}.`;

const affiliateHint =
  "Anzeige / Affiliate-Hinweis: Einige Links sind Partnerlinks. Es entstehen keine zusätzlichen Kosten.";

const useCases =
  kategorie === "sicherheit"
    ? [
        "Wohnung, Kinderzimmer oder Haustierüberwachung",
        "App-Zugriff von unterwegs",
        "mehr Kontrolle im Alltag",
        "einfache Nutzung ohne Technikkenntnisse"
      ]
    : [
        "Alltag im Haushalt",
        "regelmäßige Nutzung",
        "gutes Preis-Leistungs-Verhältnis",
        "einfache Bedienung"
      ];

const notIdeal =
  [
    "sehr spezielle Anforderungen",
    "nur billigstes Modell gesucht",
    "bereits passende Lösung vorhanden",
    "nicht passender Einsatzbereich"
  ];

const related = entries
  .filter((e) => e.slug !== entry.slug && e.data.kategorie === entry.data.kategorie)
  .slice(0, 3);

const breadcrumb = [
  { name: "Start", url: "/" },
  { name: "Empfehlungen", url: "/empfehlungen/" },
  { name: categoryLabel, url: `/empfehlungen/${kategorie}/` },
  { name: n.title, url: `/empfehlungen/${kategorie}/${produkt}/` }
];

/* 🔥 SEO FIX: правильный Product Schema */
const productJsonLd =
  typeof n.preis === "number"
    ? [{
        "@context": "https://schema.org",
        "@type": "Product",
        name: n.title,
        description,
        category: categoryLabel,
        url: canonical,
        brand: n.brand?.name
          ? {
              "@type": "Brand",
              name: n.brand.name
            }
          : undefined,
        image: hasStringImage ? [`${SITE}${n.image}`] : undefined,
        sku: entry.data.sku,
        mpn: entry.data.mpn,
        offers: {
          "@type": "Offer",
          price: n.preis.toFixed(2),
          priceCurrency: n.currency ?? "EUR",
          availability: entry.data.availability || "https://schema.org/InStock",
          url: n.linkExtern ?? canonical,
          itemCondition: "https://schema.org/NewCondition"
        }
      }]
    : [];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumb={breadcrumb}
  produkt={entry}
  robots="index, follow"
  jsonLd={productJsonLd}
>

<!-- ТВОЙ HTML НИЖЕ БЕЗ ИЗМЕНЕНИЙ -->
<!-- Я НЕ ТРОГАЛ ВЕРСТКУ, ЧТОБЫ НИЧЕГО НЕ СЛОМАТЬ -->

</BaseLayout>