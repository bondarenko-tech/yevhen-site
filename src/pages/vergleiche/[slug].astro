---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import InfoPage from "../../components/InfoPage.astro";
import { getGitDates } from "../../lib/utils/gitDates";
import { buildArticleSchema } from "../../lib/seo/article";
import { buildComparisonSchema } from "../../lib/seo/comparison";
import { kategorien } from "../../data/kategorien";
import { getRelatedVergleiche } from "@/lib/domain/vergleiche";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const SITE =
  Astro.site?.toString().replace(/\/$/, "") ??
  "https://yevhenbondarenko.com";

export async function getStaticPaths() {
  const entries = await getCollection("vergleiche");

  return entries.map((e) => ({
    params: { slug: e.slug },
  }));
}

const slug = Astro.params.slug ?? "";

const all = await getCollection("vergleiche");

const entry = all.find((e) => e.slug === slug) as
  | CollectionEntry<"vergleiche">
  | undefined;

if (!entry) {
  throw new Error(`MDX für "${slug}" nicht gefunden`);
}

const { Content } = await entry.render();
const current = entry.data;

const cat = kategorien.find((k) => k.id === current.kategorie);
const catName = cat?.name ?? current.kategorie;

const related = getRelatedVergleiche(all, entry);

const sourcePath =
  entry.filePath ?? `src/content/vergleiche/${entry.slug}.mdx`;

const { datePublished, dateModified } = getGitDates(sourcePath);

const canonical = `${SITE}/vergleiche/${slug}/`;
const title = current.title;
const description =
  current.description ??
  `${title} verständlich erklärt mit klarer Einordnung und passenden Empfehlungen.`;

const ogImage =
  typeof current.image === "string"
    ? new URL(current.image, SITE).toString()
    : undefined;

const breadcrumb = [
  { name: "Startseite", url: "/" },
  { name: "Vergleiche", url: "/vergleiche/" },
  { name: title, url: canonical },
];

const articleJsonLd = buildArticleSchema({
  title,
  description,
  canonical,
  datePublished,
  dateModified,
});

const comparisonItems = [
  { name: "Roborock Q7 M5", url: `${SITE}/empfehlungen/smart-home/roborock-q7-m5/` },
  { name: "Dreame L10s Ultra", url: `${SITE}/empfehlungen/sonstiges/dreame-l10s-ultra/` },
  { name: "MOVA E30 Ultra", url: `${SITE}/empfehlungen/sonstiges/mova-e30-ultra/` },
  { name: "Roomba Combo Essential", url: `${SITE}/empfehlungen/sonstiges/roomba-combo-essential-y011040/` },
  { name: "Roborock Saros 10R", url: `${SITE}/empfehlungen/sonstiges/roborock-saros-10r/` },
];

const comparisonJsonLd = buildComparisonSchema({
  title,
  description,
  canonical,
  items: comparisonItems,
});

const faq = (current as any).faq;

const faqJsonLd =
  Array.isArray(faq) && faq.length > 0
    ? {
        "@type": "FAQPage",
        "@id": `${canonical}#faq`,
        mainEntity: faq.map((q: { q: string; a: string }) => ({
          "@type": "Question",
          name: q.q,
          acceptedAnswer: {
            "@type": "Answer",
            text: q.a,
          },
        })),
      }
    : null;

const relatedItemListJsonLd =
  related.length > 0
    ? {
        "@type": "ItemList",
        "@id": `${canonical}#related`,
        name: `Weitere passende Vergleiche im Bereich ${catName}`,
        itemListElement: related.map((v, i) => ({
          "@type": "ListItem",
          position: i + 1,
          url: `${SITE}/vergleiche/${v.slug}/`,
          name: v.data.title,
        })),
      }
    : null;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  robots="index, follow"
  ogImage={ogImage}
  updated={dateModified}
  breadcrumb={breadcrumb}
  jsonLd={[
    articleJsonLd,
    comparisonJsonLd,
    ...(faqJsonLd ? [faqJsonLd] : []),
    ...(relatedItemListJsonLd ? [relatedItemListJsonLd] : []),
  ]}
>
  <InfoPage
    title={title}
    description={description}
    h1={title}
    datePublished={datePublished}
    dateModified={dateModified}
  >
    <div class="prose prose-neutral max-w-none">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="mt-16 rounded-[32px] border border-neutral-100 bg-neutral-50 p-8 md:p-10">
        <h2 class="mb-6 text-2xl font-black tracking-tight text-neutral-900">
          Passende Vergleiche im Bereich {catName}
        </h2>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {related.map((v) => (
            <a
              href={`/vergleiche/${v.slug}/`}
              class="group flex items-center rounded-2xl border border-neutral-200 bg-white p-4 transition-all hover:border-blue-500 hover:shadow-md"
            >
              <span class="mr-3 text-blue-600 transition-transform group-hover:translate-x-1">
                →
              </span>
              <span class="text-sm font-bold text-neutral-800 transition-colors group-hover:text-blue-600">
                {v.data.title}
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="relative mt-8 overflow-hidden rounded-[32px] bg-blue-600 p-8 text-white md:p-10">
      <div
        class="pointer-events-none absolute right-0 top-0 select-none p-8 text-8xl font-black italic opacity-10 md:text-9xl"
        aria-hidden="true"
      >
        {catName}
      </div>

      <div class="relative z-10">
        <h2 class="mb-4 text-2xl font-black">
          Konkrete Produkte aus {catName}
        </h2>

        <p class="mb-8 max-w-xl font-medium leading-relaxed text-blue-100">
          Wenn Sie nach dem Vergleich konkrete Geräte ansehen möchten, finden Sie
          hier passende Empfehlungen aus derselben Kategorie.
        </p>

        <a
          href={`/empfehlungen/${current.kategorie}/`}
          class="inline-flex items-center rounded-xl bg-white px-8 py-4 text-sm font-black text-blue-600 transition-all hover:bg-neutral-100 active:scale-95"
        >
          Alle {catName} Empfehlungen ansehen →
        </a>
      </div>
    </section>
  </InfoPage>
</BaseLayout>