---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Serverfehler (500) | Bondarenko Empfehlungen";
const description = "Ein unerwarteter Fehler ist aufgetreten. Bitte versuchen Sie es später erneut.";
const canonical = "https://yevhenbondarenko.com/500";
---

<BaseLayout title={title} description={description} canonical={canonical} robots="noindex, nofollow">

  <main class="min-h-[60vh] flex flex-col justify-center items-center text-center px-4 py-16">
    <img src="/logo.webp" alt="Logo" class="w-20 h-auto mb-6 opacity-80" />

    <h1 class="text-4xl font-bold mb-4 text-gray-900">
      500 – Serverfehler
    </h1>

    <p class="text-gray-600 max-w-md mb-6">
      Es ist ein unerwarteter Fehler aufgetreten.  
      Unser Server arbeitet daran, das Problem zu beheben.
    </p>

    <a 
      href="/" 
      class="px-6 py-3 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition">
      Zur Startseite
    </a>
  </main>

</BaseLayout>
