---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { kategorien } from "../../data/kategorien";
import type { KategorieId } from "../../types/kategorie";

/* ───────── HELPERS ───────── */
function isAbs(url?: string) {
  return !!url && /^https?:\/\//i.test(url);
}

/* ───────── DATA LAYER ───────── */
const produkte = await getCollection("produkte");

// В начале файла в блоке DATA LAYER проверь сортировку:
const items = [...produkte].sort((a, b) => {
  // Если даты нет, ставим очень старую, чтобы новые всегда были сверху
  const dateA = a.data.datum ? new Date(a.data.datum).getTime() : 0;
  const dateB = b.data.datum ? new Date(b.data.datum).getTime() : 0;
  return dateB - dateA; // Сортировка: от новых к старым
});

// Уникальность по slug (защита от дублей)
const seen = new Set<string>();
const unique = items.filter((p) =>
  seen.has(p.slug) ? false : (seen.add(p.slug), true)
);

const catMap = Object.fromEntries(
  kategorien.map((k) => [k.id, k.name])
) as Record<KategorieId, string>;

const view = unique.map((p) => {
  const image = p.data.image && isAbs(p.data.image)
      ? p.data.image
      : p.data.image || "/og-cover.jpg";

  return {
    title: p.data.title,
    teaser: p.data.description || p.data.teaser || "",
    link: `/empfehlungen/${p.data.kategorie}/${p.slug}/`,
    image,
    catId: p.data.kategorie as KategorieId,
    catLabel: catMap[p.data.kategorie as KategorieId] ?? "Technik",
  };
});

const siteUrl = Astro.site ?? new URL("https://yevhenbondarenko.com");
const canonical = new URL("/links/alle/", siteUrl).toString();

const title = "Technik-Archiv: Alle Empfehlungen | Bondarenko";
const description = "Durchsuchen Sie alle von mir vorgestellten Geräte. Unabhängige Analysen zu Smart Home, Sicherheit und Netzwerktechnik.";
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  robots="index, follow"
>
  <main class="min-h-screen bg-neutral-50/50 mx-auto max-w-6xl px-4 py-12">

    <header class="mb-10">
  <nav class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-neutral-400 mb-4">
    <a href="/" class="hover:text-blue-600">Home</a>
    <span>/</span>
    <span class="text-neutral-900">Alle Empfehlungen</span>
  </nav>

  <h1 class="text-4xl font-extrabold text-neutral-900 tracking-tight">
    Technik <span class="text-blue-600">Datenbank</span>
  </h1>
  <p class="mt-4 text-lg text-neutral-600 max-w-2xl">
    Hier findest du alle Geräte, die ich in meinen Videos analysiert habe. Nutze die Filter, um gezielt nach Lösungen zu suchen.
  </p>
</header>

<div class="sticky top-20 z-10 bg-neutral-50/90 backdrop-blur-md pb-6 pt-2 border-b border-neutral-200/50 mb-8">
  <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
    <div class="relative w-full md:max-w-md">
      <span class="absolute left-4 top-1/2 -translate-y-1/2 text-neutral-400">🔍</span>
      <input
        id="q"
        type="search"
        placeholder="Modell oder Marke suchen..."
        class="w-full rounded-xl border border-neutral-200 bg-white pl-11 pr-10 py-3 text-sm focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 outline-none transition-all shadow-sm"
      />
      <button id="clear" class="absolute right-4 top-1/2 -translate-y-1/2 hidden text-neutral-400 hover:text-neutral-900 font-bold">✕</button>
    </div>

    <div class="flex flex-wrap gap-2 justify-center">
      <button class="chip is-active" data-cat="__all">Alle</button>
      {kategorien.map((k) => (
        <button class="chip" data-cat={k.id}>
          {k.name}
        </button>
      ))}
    </div>
  </div>
  
  <p id="rescount" class="text-[11px] uppercase tracking-widest font-bold text-neutral-500 mt-6 border-l-2 border-blue-600 pl-3">
    Wird geladen...
  </p>
</div>

<section id="cards" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 pb-24">
  {view.map((item) => (
    <a 
      href={item.link} 
      class="card group flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white transition-all hover:shadow-lg"
      data-title={item.title.toLowerCase()}
      data-teaser={item.teaser.toLowerCase()}
      data-cat={item.catId}
    >
      <div class="aspect-video overflow-hidden bg-neutral-100 border-b border-neutral-100">
        <img 
          src={item.image} 
          alt={item.title} 
          class="h-full w-full object-contain p-4 transition-transform duration-500 group-hover:scale-105" 
          loading="lazy"
        />
      </div>
      
      <div class="p-4 flex flex-col flex-1">
        <span class="text-[9px] font-black uppercase tracking-widest text-blue-600 mb-2">
          {item.catLabel}
        </span>
        <h3 class="text-base font-bold text-neutral-900 leading-tight group-hover:text-blue-600 transition-colors line-clamp-2">
          {item.title}
        </h3>
        <p class="mt-2 text-xs text-neutral-500 line-clamp-2 leading-relaxed">
          {item.teaser}
        </p>
      </div>
    </a>
  ))}
</section>

<div id="nores" class="hidden py-24 text-center">
  <div class="text-5xl mb-4">🔍</div>
  <h3 class="text-xl font-bold text-neutral-900">Keine Treffer gefunden</h3>
  <p class="text-neutral-500 mt-2">Versuche es mit einem anderen Suchbegriff или сбрось фильтры.</p>
  <button onclick="document.getElementById('q').value=''; apply();" class="mt-6 text-blue-600 font-bold border-b border-blue-600 pb-1">Suche zurücksetzen</button>
</div>

    </main>
</BaseLayout>

<style>
  /* Улучшенные кнопки категорий */
  .chip {
    @apply px-5 py-2 rounded-xl text-sm font-bold border border-neutral-200 bg-white text-neutral-600 transition-all hover:border-blue-300 hover:text-blue-600 shadow-sm;
  }
  .chip.is-active {
    @apply bg-blue-600 border-blue-600 text-white shadow-md shadow-blue-200;
  }
</style>

<script is:inline>
  function apply() {
    const q = document.getElementById("q");
    const clearBtn = document.getElementById("clear");
    const cards = Array.from(document.querySelectorAll("#cards .card"));
    const chips = Array.from(document.querySelectorAll(".chip"));
    const nores = document.getElementById("nores");
    const rescount = document.getElementById("rescount");

    const query = q.value.trim().toLowerCase();
    const activeChip = chips.find((c) => c.classList.contains("is-active"));
    const cat = activeChip ? activeChip.dataset.cat : "__all";

    clearBtn.classList.toggle("hidden", !query);

    let visible = 0;
    cards.forEach((el) => {
      const okQ = !query || el.dataset.title.includes(query) || el.dataset.teaser.includes(query);
      const okCat = cat === "__all" || el.dataset.cat === cat;
      const show = okQ && okCat;
      
      el.style.display = show ? "" : "none";
      if (show) visible++;
    });

    // Показываем/скрываем блок "Ничего не найдено"
    if (nores) nores.classList.toggle("hidden", visible !== 0);
    
    // Формируем понятный статус для юзера
    const catName = cat === "__all" ? "alle Kategorien" : activeChip.textContent.trim();
    const queryPart = query ? ` für "${query}"` : "";
    
    rescount.innerHTML = `Gefunden: <span class="text-blue-600">${visible}</span> Produkte${queryPart} in <span class="text-neutral-900">${catName}</span>`;
  }

  document.addEventListener("DOMContentLoaded", () => {
    const q = document.getElementById("q");
    const clearBtn = document.getElementById("clear");
    const chips = document.querySelectorAll(".chip");

    q.addEventListener("input", apply);
    
    clearBtn.addEventListener("click", () => {
      q.value = "";
      apply();
    });

    chips.forEach((btn) => {
      btn.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("is-active"));
        btn.classList.add("is-active");
        apply();
      });
    });

    apply();
  });
</script>