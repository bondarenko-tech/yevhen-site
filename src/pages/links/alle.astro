---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { kategorien } from "../../data/kategorien";

const produkte = await getCollection("produkte");

/* Сортировка по дате */
const items = [...produkte].sort((a, b) => {
  const dateA = a.data.datum ? new Date(a.data.datum).getTime() : 0;
  const dateB = b.data.datum ? new Date(b.data.datum).getTime() : 0;
  return dateB - dateA;
});

const view = items.map((p) => ({
  title: p.data.title,
  teaser: p.data.description || p.data.teaser || "",
  link: `/empfehlungen/${p.data.kategorie}/${p.slug}/`,
  image: p.data.image || "/og-cover.jpg",
  cat: p.data.kategorie
}));

const title = "Technik Datenbank – Alle Geräte";
const description = "Übersicht aller analysierten Technikgeräte.";
---

<BaseLayout title={title} description={description}>

<!-- 🔴 ВАЖНО: закрываем от индекса -->
<meta name="robots" content="noindex, follow" />

<main class="max-w-7xl mx-auto px-4 py-12">

  <header class="mb-10">
    <h1 class="text-4xl font-bold mb-4">
      Technik Datenbank
    </h1>

    <p class="text-neutral-600">
      Übersicht aller Geräte. Nutze die Suche, um schnell passende Produkte zu finden.
    </p>
  </header>

  <!-- Поиск -->
  <input
    id="q"
    type="search"
    placeholder="Suche nach Modell oder Marke..."
    class="w-full max-w-xl border rounded-xl px-4 py-3 mb-8"
  />

  <!-- Карточки -->
  <section id="cards" class="grid md:grid-cols-3 gap-6">

    {view.map(item => (
      <a
        href={item.link}
        class="border rounded-xl p-4 hover:shadow-sm transition block"
        data-title={item.title.toLowerCase()}
      >
        <img src={item.image} alt={item.title} class="mb-3" />

        <h3 class="font-semibold">
          {item.title}
        </h3>

        <p class="text-sm text-neutral-600">
          {item.teaser}
        </p>
      </a>
    ))}

  </section>

</main>

<script is:inline>
  const q = document.getElementById("q");
  const cards = document.querySelectorAll("#cards a");

  q.addEventListener("input", () => {
    const val = q.value.toLowerCase();

    cards.forEach(card => {
      const text = card.dataset.title;
      card.style.display = text.includes(val) ? "block" : "none";
    });
  });
</script>

</BaseLayout>