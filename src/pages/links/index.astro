---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { kategorien } from "../../data/kategorien";

const produkte = await getCollection("produkte");

function parseDate(d?: string) {
  if (!d) return 0;
  const t = Date.now();
  return Number.isNaN(t) ? 0 : t;
}

const sorted = [...produkte].sort(
  (a, b) => parseDate(b.data.datum) - parseDate(a.data.datum)
);

const latest = sorted.slice(0, 12);
const catMap = Object.fromEntries(kategorien.map((k) => [k.id, k.name]));

const view = latest.map((p) => ({
  title: p.data.title,
  teaser: p.data.teaser ?? "",
  link: `/empfehlungen/${p.data.kategorie}/${p.slug}/`,
  image: p.data.image || "/og-cover.jpg",
  catLabel: catMap[p.data.kategorie] ?? "Technik",
}));

const siteUrl = Astro.site ?? new URL("https://yevhenbondarenko.com");
const canonical = new URL("/links/", siteUrl).toString();
---

<BaseLayout
  title="Technik-Links | Bondarenko Empfehlungen"
  description="Kompakte Übersicht der Technik-Empfehlungen aus unseren Analysen."
  canonical={canonical}
>
  <main class="mx-auto max-w-6xl px-4 py-8 md:py-12">

    <header class="mb-10 border-b border-neutral-100 pb-8">
      <h1 class="text-3xl font-black tracking-tighter text-neutral-900 md:text-5xl mb-3">
        Technik <span class="text-blue-600">Referenz-Links</span>
      </h1>
      <p class="text-base text-neutral-500 max-w-2xl">
        Schneller Zugriff auf alle analysierten Geräte und Hardware-Komponenten aus meinen Videos.
      </p>
    </header>

    <div class="mb-10 rounded-2xl bg-neutral-50 p-5 border border-neutral-100 flex gap-4 items-center shadow-sm">
      <span class="text-xl">ℹ️</span>
      <p class="text-xs text-neutral-600 leading-normal">
        <strong>Hinweis:</strong> Transparente Finanzierung durch Affiliate-Links. Für dich entstehen keine Zusatzkosten.
      </p>
    </div>

    <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {view.map((p) => (
        <a
          href={p.link}
          class="group flex flex-col rounded-2xl border border-neutral-200 overflow-hidden hover:border-blue-500 hover:shadow-lg transition-all bg-white"
        >
          <figure class="aspect-video overflow-hidden bg-neutral-100 relative border-b border-neutral-100">
            <img
              src={p.image}
              alt={p.title}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute top-2 left-2 bg-neutral-900/90 text-white text-[8px] font-bold uppercase tracking-widest px-2 py-1 rounded shadow-sm">
                Analyse
            </div>
          </figure>

          <div class="p-4 flex flex-col flex-grow">
            <span class="text-[9px] font-bold uppercase tracking-widest text-blue-600 mb-1">{p.catLabel}</span>
            <h2 class="text-base font-bold text-neutral-900 leading-tight group-hover:text-blue-600 transition-colors line-clamp-2 min-h-[2.5rem]">
              {p.title}
            </h2>

            <p class="text-[11px] text-neutral-500 mt-2 line-clamp-2 leading-relaxed flex-grow">
              {p.teaser}
            </p>

            <div class="mt-4 pt-4 border-t border-neutral-50 flex items-center justify-between">
              <span class="text-[10px] font-black text-neutral-900 uppercase tracking-tighter group-hover:text-blue-600 transition-colors">
                Details →
              </span>
              <span class="text-[9px] text-neutral-400 font-medium italic">Amazon Partner</span>
            </div>
          </div>
        </a>
      ))}
    </section>

    <div class="mt-16 text-center">
      <a
        href="/links/alle/"
        class="inline-block rounded-xl border border-neutral-200 px-8 py-3 text-xs font-bold text-neutral-600 hover:bg-neutral-900 hover:text-white transition-all"
      >
        Alle Empfehlungen anzeigen
      </a>
    </div>

  </main>
</BaseLayout>