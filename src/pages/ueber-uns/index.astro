---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Über dieses Projekt – Technik einfach erklärt";
const description =
  "Unabhängige Produktübersichten und einfache technische Erklärungen von Yevhen Bondarenko.";

const site = Astro.site ?? new URL("https://yevhenbondarenko.com");
const canonical = new URL("/ueber-uns/", site).toString();
const ogImage = new URL("/images/bondarenko.webp", site).toString();
---

<BaseLayout 
  title={title} 
  description={description}
  ogImage={ogImage}
  canonical={canonical}
>
  <main class="mx-auto max-w-6xl px-4 py-12 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      
      {/* LEFT */}
      <div class="lg:col-span-5 space-y-8 lg:sticky lg:top-28">
        <div class="bg-white rounded-[32px] overflow-hidden border border-neutral-100">
          <img 
            src="/images/bondarenko.webp" 
            alt="Yevhen Bondarenko" 
            class="w-full h-auto object-cover"
          />
          <div class="p-6 bg-neutral-900 text-white">
            <p class="text-xs uppercase tracking-wider text-neutral-400 mb-1">
              Projekt
            </p>
            <p class="text-base font-bold">Yevhen Bondarenko</p>
          </div>
        </div>

        <div class="text-neutral-500 text-sm">
          📍 Deutschland
        </div>
      </div>

      {/* RIGHT */}
      <div class="lg:col-span-7">
        <section class="prose prose-neutral max-w-none">
          
          <h1 class="text-4xl md:text-5xl font-black text-neutral-900 leading-tight mb-8">
            Technik verstehen <br/>
            <span class="text-blue-600">ohne Marketingversprechen</span>
          </h1>

          <div class="space-y-6 text-lg text-neutral-600 leading-relaxed">

            <p>
              Diese Website ist ein unabhängiges Projekt von <strong>Yevhen Bondarenko</strong>.
            </p>

            <p>
              Hier werden technische Produkte vorgestellt und grundlegende Unterschiede einfach erklärt – ohne Verkaufsdruck und ohne unnötige Komplexität.
            </p>

            <p>
              Ziel ist es, typische Funktionen, Einsatzbereiche und mögliche Unterschiede verständlich darzustellen.
            </p>

            <div class="bg-neutral-50 border-l-4 border-blue-600 p-6 my-10 rounded-r-2xl">
              <p class="text-neutral-900 font-semibold italic m-0">
                "Diese Inhalte dienen zur Orientierung und stellen keine Beratung oder individuelle Empfehlung dar."
              </p>
            </div>

            <h2 class="text-2xl font-bold text-neutral-900 pt-6">
              Wie diese Website funktioniert
            </h2>

            <div class="space-y-4 text-base text-neutral-600">

              <p>
                Die Inhalte basieren auf öffentlich verfügbaren Informationen und typischen Produkteigenschaften.
              </p>

              <p>
                Es findet kein Verkauf von Produkten statt. Diese Website ist kein Online-Shop.
              </p>

              <p>
                Einige Links sind sogenannte Partnerlinks (z. B. Amazon). Wenn Sie darüber einkaufen, kann eine Provision entstehen – ohne zusätzliche Kosten für Sie.
              </p>

            </div>

          </div>

          <div class="mt-12">
            <a href="/empfehlungen/" class="bg-blue-600 text-white px-8 py-4 rounded-2xl font-bold hover:bg-blue-700 transition-all inline-block">
              Alle Produkte ansehen
            </a>
          </div>

        </section>
      </div>
    </div>
  </main>
</BaseLayout>