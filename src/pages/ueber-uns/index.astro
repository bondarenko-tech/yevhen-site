---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Über dieses Projekt | Yevhen Bondarenko";
const description =
  "Unabhängige Produktübersichten, technische Einordnung und verständliche Erklärungen von Yevhen Bondarenko.";

const site = Astro.site ?? new URL("https://yevhenbondarenko.com");
const canonical = new URL("/ueber-uns/", site).toString();
const ogImage = new URL("/images/bondarenko.webp", site).toString();
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonical={canonical}
>
  <main class="mx-auto max-w-6xl px-4 py-12 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      <div class="lg:col-span-5 space-y-8 lg:sticky lg:top-28">
        <div class="bg-white rounded-[32px] overflow-hidden border border-neutral-100 shadow-sm">
          <div class="aspect-[4/3] bg-neutral-50 flex items-center justify-center p-10">
            <div class="text-center">
              <img
                src="/images/bondarenko.webp"
                alt="Bondarenko Empfehlungen"
                class="w-full max-w-[220px] mx-auto object-contain"
              />
            </div>
          </div>

          <div class="p-6 bg-neutral-900 text-white">
            <p class="text-xs uppercase tracking-wider text-neutral-400 mb-1">
              Projekt
            </p>
            <p class="text-lg font-bold">Bondarenko Empfehlungen</p>
            <p class="text-sm text-neutral-400 mt-1">
              von Yevhen Bondarenko
            </p>
          </div>
        </div>

        <div class="text-neutral-500 text-sm">
          📍 Deutschland
        </div>
      </div>

      <div class="lg:col-span-7">
        <section class="prose prose-neutral max-w-none">
          <h1 class="text-4xl md:text-5xl font-black text-neutral-900 leading-tight mb-8">
            Technik verstehen <br />
            <span class="text-blue-600">klarer und einfacher</span>
          </h1>

          <div class="space-y-6 text-lg text-neutral-600 leading-relaxed">
            <p>
              Diese Website ist ein unabhängiges Projekt von <strong>Yevhen Bondarenko</strong>
              und wird unter dem Projektnamen <strong>Bondarenko Empfehlungen</strong> betrieben.
            </p>

            <p>
              Hier werden technische Produkte und ihre typischen Unterschiede verständlich eingeordnet,
              damit Funktionen, Einsatzbereiche und wesentliche Merkmale schneller erfasst werden können.
            </p>

            <p>
              Ziel ist es, Orientierung zu bieten – ohne unnötige Fachsprache und ohne den Anspruch,
              einen Online-Shop oder eine individuelle Beratung zu ersetzen.
            </p>

            <div class="bg-neutral-50 border border-neutral-200 p-6 rounded-2xl my-8">
              <h2 class="text-xl font-bold text-neutral-900 mb-3">
                Worum es bei Bondarenko Empfehlungen geht
              </h2>

              <p class="text-base text-neutral-600 leading-relaxed">
                Bondarenko Empfehlungen ist ein Content-Projekt mit Produktübersichten,
                Vergleichen und technischen Erklärungen. Es handelt sich nicht um einen Online-Shop:
                Es erfolgt kein Verkauf, keine Lagerhaltung und kein Versand von Produkten.
              </p>
            </div>

            <div class="bg-neutral-50 border-l-4 border-blue-600 p-6 my-10 rounded-r-2xl">
              <p class="text-neutral-900 font-semibold italic m-0">
                "Diese Inhalte dienen der Orientierung und ersetzen keine individuelle Beratung."
              </p>
            </div>

            <h2 class="text-2xl font-bold text-neutral-900 pt-6">
              Wie diese Website funktioniert
            </h2>

            <div class="space-y-4 text-base text-neutral-600">
              <p>
                Die Inhalte basieren auf öffentlich verfügbaren Informationen, technischen Daten,
                Herstellerangaben und redaktioneller Einordnung.
              </p>

              <p>
                Es findet kein Verkauf von Produkten statt. Diese Website ist kein Online-Shop.
              </p>

              <p>
                Einige Links sind Partnerlinks, unter anderem zu Amazon.
                Wenn über solche Links ein Kauf erfolgt, kann eine Provision anfallen – ohne zusätzliche Kosten für Sie.
              </p>
            </div>
          </div>

          <div class="mt-12">
            <a href="/empfehlungen/" class="bg-blue-600 text-white px-8 py-4 rounded-2xl font-bold hover:bg-blue-700 transition-all inline-block">
              Alle Übersichten ansehen
            </a>

            <div class="mt-6 flex flex-wrap gap-4 text-sm">
              <a href="/impressum/" class="text-blue-600 hover:underline">Impressum</a>
              <a href="/transparenz/" class="text-blue-600 hover:underline">Transparenz</a>
              <a href="/kontakt/" class="text-blue-600 hover:underline">Kontakt</a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>