---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("vergleiche");

articles.sort((a, b) => {
  const da = new Date(a.data?.datum ?? "2020-01-01").getTime();
  const db = new Date(b.data?.datum ?? "2020-01-01").getTime();
  return db - da;
});
---

<BaseLayout
  title="Technik vergleichen – Kaufberatung & Vergleiche"
  description="Vergleiche zu Sicherheit, Netzwerk, Strom und Smart Home. Klar erklärt und direkt auf den Punkt."
>
  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-16">
    <header class="mb-12 md:mb-16">
      <h1 class="text-3xl md:text-5xl font-black text-neutral-900 mb-6 tracking-tight">
        Technik <span class="text-blue-600">vergleichen</span>
      </h1>

      <p class="text-lg text-neutral-700 max-w-3xl leading-relaxed">
        Hier finden Sie strukturierte Analysen zu Geräten aus den Bereichen Strom,
        Sicherheit und Smart Home. Kein Marketing-Blabla, sondern echte Fakten für
        Ihre Entscheidung.
      </p>
    </header>

    <section class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
      {articles.map((article) => {
        const imageSrc =
          typeof article.data.image === "string"
            ? article.data.image
            : article.data.image?.src;

        return (
          <a
            href={`/vergleiche/${article.slug}/`}
            class="block rounded-3xl border border-neutral-200 bg-white overflow-hidden hover:shadow-lg transition"
          >
            {imageSrc && (
              <img
                src={imageSrc}
                alt={article.data.title}
                class="w-full aspect-[16/9] object-cover"
                loading="lazy"
              />
            )}

            <div class="p-6">
              <div class="inline-flex text-xs font-bold uppercase tracking-wide text-blue-600 mb-3">
                {article.data.kategorie}
              </div>

              <h2 class="text-2xl font-black text-neutral-900 mb-4 leading-tight">
                {article.data.title}
              </h2>

              <p class="text-neutral-600 leading-relaxed">
                {article.data.description}
              </p>
            </div>
          </a>
        );
      })}
    </section>
  </main>
</BaseLayout>