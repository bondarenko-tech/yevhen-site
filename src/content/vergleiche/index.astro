---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("vergleiche");

function getSlug(entry: any) {
  return entry.id.replace(/\.mdx?$/, "");
}

articles.sort((a, b) => {
  const da = new Date(a.data?.datum ?? "2020-01-01").getTime();
  const db = new Date(b.data?.datum ?? "2020-01-01").getTime();
  return db - da;
});
---

<BaseLayout
  title="Technik vergleichen – Kaufberatung & Vergleiche"
  description="Vergleiche zu Sicherheit, Netzwerk, Strom und Smart Home. Klar erklärt und direkt auf den Punkt."
>
  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-16">
    <header class="mb-12 md:mb-16">
      <span class="inline-flex items-center rounded-full bg-blue-50 px-4 py-1 text-xs font-bold uppercase tracking-[0.18em] text-blue-600 mb-5">
        Kaufberatung
      </span>

      <h1 class="text-3xl md:text-5xl font-black text-neutral-900 mb-6 tracking-tight">
        Technik <span class="text-blue-600">vergleichen</span>
      </h1>

      <p class="text-lg text-neutral-700 max-w-3xl leading-relaxed">
        Hier finden Sie strukturierte Vergleiche zu Netzwerk, Sicherheit, Strom und Smart Home.
        Ziel ist eine klare Entscheidung: Welche Lösung passt wirklich zu Ihrem Zuhause?
      </p>
    </header>

    <section class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
      {articles.map((article) => {
        const slug = getSlug(article);

        const imageSrc =
          typeof article.data.image === "string"
            ? article.data.image
            : article.data.image?.src;

        const href = `/vergleiche/${slug}/`;

        return (
          <a
            href={href}
            class="group block overflow-hidden rounded-3xl border border-neutral-200 bg-white hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200"
          >
            <div class="p-4 pb-0">
              <span class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-blue-600">
                {article.data.kategorie}
              </span>
            </div>

            {imageSrc && (
              <div class="px-4 pt-4">
                <img
                  src={imageSrc}
                  alt={article.data.title}
                  class="w-full aspect-[16/9] object-cover rounded-2xl border border-neutral-100"
                  loading="lazy"
                />
              </div>
            )}

            <div class="p-6">
              <h2 class="text-2xl font-black text-neutral-900 leading-tight mb-4 group-hover:text-blue-700 transition-colors">
                {article.data.title}
              </h2>

              {article.data.description && (
                <p class="text-neutral-600 leading-relaxed">
                  {article.data.description}
                </p>
              )}
            </div>
          </a>
        );
      })}
    </section>
  </main>
</BaseLayout>