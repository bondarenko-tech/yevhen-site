---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("verstehen");

// Сортировка: самые свежие гайды в начале
articles.sort((a, b) => {
  const da = new Date(a.data?.datum ?? "2020-01-01").getTime();
  const db = new Date(b.data?.datum ?? "2020-01-01").getTime();
  return db - da;
});
---

<BaseLayout
  title="Technik verstehen – einfache Erklärungen für Zuhause"
  description="WLAN im Altbau, Mesh-Systeme und Repeater einfach erklärt. Wir helfen Ihnen, Technik ohne Fachchinesisch zu verstehen."
>
  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-black text-neutral-900 mb-6 tracking-tight leading-tight">
        Technik <span class="text-blue-600">verstehen</span> – Wissen für Zuhause
      </h1>
      <p class="text-lg text-neutral-600 max-w-3xl leading-relaxed">
        Viele Technik-Probleme entstehen durch die falsche Auswahl oder Konfiguration. 
        In unseren Ratgebern erklären wir komplexe Themen — von Mesh-WLAN bis Powerline — mit einfachen Worten.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {articles.map((a) => (
        <a
          href={`/verstehen/${a.slug}/`}
          class="group flex flex-col bg-white border border-neutral-100 rounded-[24px] md:rounded-[32px] overflow-hidden hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500 active:scale-[0.98]"
        >
          {/* Визуальный блок гайда */}
          <div class="relative aspect-[16/9] overflow-hidden bg-blue-50 flex items-center justify-center">
            {a.data.image ? (
              <img 
                src={a.data.image} 
                alt={a.data.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              />
            ) : (
              /* Фолбек-иконка */
              <div class="flex flex-col items-center gap-2 text-blue-300">
                <span class="text-5xl">📖</span>
              </div>
            )}
            
            <div class="absolute bottom-4 left-4">
               <span class="bg-blue-600 text-white px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider shadow-lg">
                Ratgeber
               </span>
            </div>
          </div>

          {/* Текст гайда */}
          <div class="p-6 md:p-8 flex flex-col flex-grow">
            <h3 class="text-xl font-bold text-neutral-900 mb-3 group-hover:text-blue-600 transition-colors leading-snug">
              {a.data.title}
            </h3>

            {a.data.description && (
              <p class="text-neutral-500 text-sm leading-relaxed mb-6 line-clamp-3">
                {a.data.description}
              </p>
            )}

            <div class="mt-auto flex items-center text-sm font-bold text-blue-600 gap-2">
              Artikel lesen
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-20 p-8 md:p-12 bg-neutral-50 rounded-[32px] border border-neutral-100 text-center">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">Haben Sie eine spezifische Frage?</h2>
      <p class="text-neutral-600 mb-0">
        Wir erweitern unsere Wissensdatenbank ständig. Schauen Sie regelmäßig vorbei für neue Tipps rund um WLAN und Smart Home.
      </p>
    </div>
  </main>
</BaseLayout>