---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("verstehen");

function getSlug(entry: any) {
  return entry.id.replace(/\.mdx?$/, "");
}

articles.sort((a, b) => {
  const da = new Date(a.data?.datum ?? "2020-01-01").getTime();
  const db = new Date(b.data?.datum ?? "2020-01-01").getTime();
  return db - da;
});
---

<BaseLayout
  title="Technik verstehen – einfache Erklärungen für WLAN, Smart Home & Netzwerk"
  description="Einfache Ratgeber zu WLAN, Mesh, Repeater, Powerline und Smart Home. Verständlich erklärt für Zuhause – ohne Fachchinesisch."
>
  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    
    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-black text-neutral-900 mb-6 tracking-tight leading-tight">
        Technik <span class="text-blue-600">verstehen</span> – einfache Hilfe für Zuhause
      </h1>

      <p class="text-lg text-neutral-600 max-w-3xl leading-relaxed">
        Hier finden Sie verständliche Erklärungen zu WLAN, Mesh, Repeater, Powerline und Smart Home.
        Ziel ist nicht Technik-Theorie, sondern klare Hilfe für echte Probleme im Alltag.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {articles.map((a) => {
        const slug = getSlug(a);

        return (
          <a
            href={`/verstehen/${slug}/`}
            class="group flex flex-col bg-white border border-neutral-100 rounded-[24px] md:rounded-[32px] overflow-hidden hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500 active:scale-[0.98]"
          >
            <div class="relative aspect-[16/9] overflow-hidden bg-blue-50 flex items-center justify-center">
              {a.data.image ? (
                <img 
                  src={a.data.image} 
                  alt={a.data.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                  loading="lazy"
                />
              ) : (
                <div class="flex flex-col items-center gap-2 text-blue-300">
                  <span class="text-5xl">📖</span>
                </div>
              )}
              
              <div class="absolute bottom-4 left-4">
                <span class="bg-blue-600 text-white px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider shadow-lg">
                  Ratgeber
                </span>
              </div>
            </div>

            <div class="p-6 md:p-8 flex flex-col flex-grow">
              <h2 class="text-xl font-bold text-neutral-900 mb-3 group-hover:text-blue-600 transition-colors leading-snug">
                {a.data.title}
              </h2>

              {a.data.description && (
                <p class="text-neutral-500 text-sm leading-relaxed mb-6 line-clamp-3">
                  {a.data.description}
                </p>
              )}

              <div class="mt-auto flex items-center text-sm font-bold text-blue-600 gap-2">
                Artikel lesen
                <span class="group-hover:translate-x-1 transition-transform">→</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <section class="mt-20 p-8 md:p-12 bg-neutral-50 rounded-[32px] border border-neutral-100 text-center">
      <h2 class="text-2xl font-bold text-neutral-900 mb-4">
        WLAN oder Smart Home Problem?
      </h2>
      <p class="text-neutral-600 mb-0">
        Starten Sie mit den Grundlagen und wählen Sie danach die passende Lösung: Repeater, Mesh, Powerline oder Smart-Home-Geräte.
      </p>
    </section>
  </main>
</BaseLayout>