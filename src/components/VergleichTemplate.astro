---
import { getCollection } from "astro:content";
import { buildVergleich } from "../lib/buildVergleich";
import CategoryProductCard from "./CategoryProductCard.astro";
import { normalizeProduct } from "../lib/product-engine";

interface Props {
  title: string;
  intro: string;
  slugs: string[];
}

const { title, intro, slugs } = Astro.props;

/* ───────── Content Layer ───────── */

const allProdukteRaw = await getCollection("produkte");

/* 🔐 ЖЁСТКАЯ НОРМАЛИЗАЦИЯ */
const allProdukte = allProdukteRaw.map((p) => ({
  ...p,
  data: {
    ...p.data,
    preis:
      typeof p.data.preis === "number"
        ? p.data.preis
        : undefined,
    brand:
      typeof p.data.brand === "string"
        ? p.data.brand
        : p.data.brand?.name ?? "",
  },
}));

const { produkte, winnerBudget, winnerPremium } =
  buildVergleich(allProdukte, slugs);

/* ───────── Helpers ───────── */

const formatPrice = (price?: number) =>
  typeof price === "number"
    ? new Intl.NumberFormat("de-DE", {
        style: "currency",
        currency: "EUR",
      }).format(price)
    : "-";

const buildLink = (p: typeof produkte[number]) =>
  `/empfehlungen/${p.data.kategorie}/${p.slug}/`;

/* 🔐 SAFE PREISE */
const budgetPreis =
  typeof winnerBudget?.data?.preis === "number"
    ? winnerBudget.data.preis
    : undefined;

const premiumPreis =
  typeof winnerPremium?.data?.preis === "number"
    ? winnerPremium.data.preis
    : undefined;
---

<section class="mx-auto max-w-6xl px-4 py-12">

  <h1 class="text-3xl font-bold mb-4">
    {title}
  </h1>

  <p class="text-neutral-700 mb-10 max-w-2xl">
    {intro}
  </p>

  {/* 🎯 Schnellentscheidung */}
  {(winnerBudget || winnerPremium) && (
    <div class="mb-14 bg-blue-50 border rounded-2xl p-8">
      <h2 class="text-xl font-semibold mb-6">
        Schnellentscheidung
      </h2>

      <div class="grid md:grid-cols-2 gap-6 text-sm">

        {winnerBudget && (
          <div class="bg-white rounded-xl p-5 border">

            <div class="text-green-600 font-semibold mb-2">
              🏆 Preis-Leistungs-Tipp
            </div>

            <div class="font-medium mb-2">
              {winnerBudget.data.title}
            </div>

            <div class="mb-4">
              {formatPrice(budgetPreis)}
            </div>

            <a
              href={buildLink(winnerBudget)}
              class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition"
            >
              Zum Produkt →
            </a>

          </div>
        )}

        {winnerPremium && (
          <div class="bg-white rounded-xl p-5 border">

            <div class="text-blue-600 font-semibold mb-2">
              ⭐ Premium-Empfehlung
            </div>

            <div class="font-medium mb-2">
              {winnerPremium.data.title}
            </div>

            <div class="mb-4">
              {formatPrice(premiumPreis)}
            </div>

            <a
              href={buildLink(winnerPremium)}
              class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition"
            >
              Zum Produkt →
            </a>

          </div>
        )}

      </div>
    </div>
  )}

  {/* 📊 Vergleichstabelle */}
  <div class="overflow-x-auto mb-14">
    <table class="w-full border text-sm">
      <thead class="bg-neutral-100">
        <tr>
          <th class="p-3 text-left">Produkt</th>
          <th class="p-3 text-left">Preis</th>
          <th class="p-3 text-left">Typ</th>
          <th class="p-3 text-left">Marke</th>
        </tr>
      </thead>
      <tbody>
        {produkte.map((p) => (
          <tr class="border-t">
            <td class="p-3 font-medium">
              {p.data.title}
            </td>
            <td class="p-3">
              {formatPrice(
                typeof p.data.preis === "number"
                  ? p.data.preis
                  : undefined
              )}
            </td>
            <td class="p-3">
              {p.data.typ ?? "-"}
            </td>
            <td class="p-3">
              {p.data.brand || "-"}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  {/* 🧩 Produktkarten */}
  <div class="grid gap-6 sm:grid-cols-2">

{produkte.map((p) => (
  <CategoryProductCard p={normalizeProduct(p)} />
))}

</div>

</section>