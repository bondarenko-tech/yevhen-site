---
import type { CollectionEntry } from "astro:content";
import { slugify } from "../lib/slugify";

export interface Props {
  produkt: CollectionEntry<"produkte">;
}

const { produkt } = Astro.props;
const data = produkt.data;

const brandName = typeof data.brand === "string" ? data.brand : data.brand?.name ?? null;
const brandSlug = brandName ? slugify(brandName) : null;

const image = typeof data.image === "string" && data.image.length > 0 ? data.image : "/og-cover.jpg";

const price = typeof data.preis === "number"
  ? new Intl.NumberFormat("de-DE", {
      style: "currency",
      currency: data.priceCurrency || "EUR",
      maximumFractionDigits: 0,
    }).format(data.preis)
  : null;
---

<header class="bg-white py-12 md:py-20 border-b border-neutral-100">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      
      <div>
        <nav class="text-[10px] uppercase text-blue-600 font-bold tracking-widest mb-4">
          <a href={`/empfehlungen/${data.kategorie}/`}>{data.kategorie}</a>
          {brandName && <> / {brandName}</>}
        </nav>

        <h1 class="text-3xl md:text-5xl font-black mb-4">
          {data.title}
        </h1>

        {/* 🔥 MINI FAZIT */}
        <p class="text-lg text-neutral-700 mb-6">
          Kurz gesagt: {data.teaser}
        </p>

        {/* 🔥 FÜR WEN */}
        <div class="mb-6 text-sm text-neutral-600">
          <strong>Geeignet für:</strong>
          <ul class="mt-2 space-y-1">
            <li>• Altbau Wohnungen</li>
            <li>• mehrere Geräte gleichzeitig</li>
            <li>• Home-Office & Streaming</li>
          </ul>
        </div>

        <div class="flex items-center gap-6">
          {data.linkExtern && (
            <a
              href={data.linkExtern}
              target="_blank"
              rel="nofollow sponsored noopener"
              class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg text-sm font-bold"
            >
              👉 Bei Amazon ansehen
            </a>
          )}

          {price && (
            <span class="text-xl font-bold">{price}</span>
          )}
        </div>

        {/* 🔐 LEGAL */}
        <p class="text-xs text-neutral-400 mt-4">
          Affiliate-Link. Kein Verkauf durch diese Website.
        </p>
      </div>

      <div class="flex justify-center">
        <img
          src={image}
          alt={data.title}
          class="max-h-[300px] object-contain"
        />
      </div>

    </div>
  </div>
</header>