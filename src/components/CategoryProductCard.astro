---
import type { NormalizedProduct } from "../lib/product-engine/types";

interface Props {
  p: NormalizedProduct;
}

const { p } = Astro.props;

/* IMAGE LOGIC */
const img = typeof p.image === "string" && p.image.length > 0 ? p.image : "/og-cover.jpg";

/* CONTENT */
const title = p.title ?? "";
const teaser = p.teaser ?? "";
const link = p.linkIntern ?? "#";

/* PRICE FORMATTING */
const price = typeof p.preis === "number"
    ? new Intl.NumberFormat("de-DE", {
        style: "currency",
        currency: p.currency ?? "EUR"
      }).format(p.preis)
    : null;

const isFeatured = p.featured === true;
---

<a
  href={link}
  aria-label={`Produkt ansehen: ${title}`}
  class="group flex flex-col bg-white border border-neutral-100 rounded-[32px] overflow-hidden transition-all duration-500 hover:shadow-2xl hover:shadow-blue-500/5 hover:-translate-y-1 active:scale-[0.98]"
>
  {/* Image Container */}
  <div class="relative aspect-square w-full bg-neutral-50 p-6 overflow-hidden">
    {isFeatured && (
      <div class="absolute top-4 left-4 z-10">
        <span class="bg-blue-600 text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full shadow-lg shadow-blue-500/30">
          Empfehlung
        </span>
      </div>
    )}

    <img
      src={img}
      alt={title}
      class="h-full w-full object-contain mix-blend-multiply transition-transform duration-700 group-hover:scale-110"
      loading="lazy"
    />
  </div>

  {/* Content Container */}
  <div class="p-8 flex flex-col flex-grow">
    <h3 class="text-lg font-bold leading-tight text-neutral-900 group-hover:text-blue-600 transition-colors">
      {title}
    </h3>

    {teaser && (
      <p class="mt-3 text-sm text-neutral-500 line-clamp-2 leading-relaxed font-medium">
        {teaser}
      </p>
    )}

    {/* Price & Action Footer */}
    <div class="mt-auto pt-6 flex items-center justify-between">
      {price ? (
        <div class="flex flex-col">
          <span class="text-xl font-black text-neutral-900">{price}</span>
          <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-tighter">bei Amazon</span>
        </div>
      ) : (
        <span class="text-xs font-bold text-neutral-400 uppercase">Preis prüfen</span>
      )}

      <div class="h-12 w-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 15.707a1 1 0 010-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 111.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
      </div>
    </div>
  </div>
</a>