---
interface Props {
  title: string;
  description: string;
  currentUrl: string;
  canonical?: string;
  robots?: string;
  image?: string;
  isProduct?: boolean;
}

const {
  title,
  description,
  currentUrl,
  canonical,
  robots = "index, follow",
  image = "/og/site.webp",
  isProduct = false,
} = Astro.props as Props;

const site = "https://yevhenbondarenko.com";
const siteName = "Yevhen Bondarenko – Smarte Technik";

const path = Astro.url.pathname;
const searchParams = Astro.url.searchParams;

function ensureAbsoluteUrl(url: string) {
  return url.startsWith("http") ? url : new URL(url, site).toString();
}

function normalizeUrl(url: string) {
  const u = ensureAbsoluteUrl(url);
  return u.endsWith("/") ? u : `${u}/`;
}

function safeDescription(text?: string): string {
  const base =
    text?.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim() ||
    "Unabhängige Produktübersichten und verständliche Technik-Vergleiche für Smart Home, Sicherheit und Haushalt.";

  return base.length <= 155
    ? base
    : base.slice(0, 155).replace(/\s+\S*$/, "").trim();
}

function safeTitle(text?: string): string {
  const base = text?.replace(/\s+/g, " ").trim() || siteName;
  return base.length <= 65
    ? base
    : base.slice(0, 65).replace(/\s+\S*$/, "").trim();
}

const finalTitle = safeTitle(title);
const finalDescription = safeDescription(description);

const finalUrl = normalizeUrl(currentUrl);
const canonicalUrl = normalizeUrl(canonical || finalUrl);
const ogImage = ensureAbsoluteUrl(image);

const isNoindex =
  path.startsWith("/shorts/") ||
  path.startsWith("/video/") ||
  path.startsWith("/links/") ||
  path.startsWith("/admin/") ||
  path.includes(".astro") ||
  searchParams.has("q");

const finalRobots = isNoindex ? "noindex, follow" : robots;
const ogType = isProduct ? "product" : "website";
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#ffffff" />
<meta name="generator" content={Astro.generator} />
<meta name="referrer" content="strict-origin-when-cross-origin" />

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<title>{finalTitle}</title>
<link rel="canonical" href={canonicalUrl} />

<meta name="description" content={finalDescription} />
<meta name="robots" content={finalRobots} />
<meta name="author" content="Yevhen Bondarenko" />
<meta name="language" content="de" />
<meta http-equiv="content-language" content="de-DE" />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={finalTitle} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="de_DE" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={ogImage} />