---
import { getCollection } from "astro:content";
import { buildMoneyFaq } from "../lib/affiliate/moneyFaq";
import { buildMoneyPage } from "../lib/affiliate/moneyPage";

import CategoryProductCard from "./CategoryProductCard.astro";

import type { ProduktTyp } from "../lib/domain/product";
import type { CollectionEntry } from "astro:content";
import type { NormalizedProduct } from "../lib/product-engine/types";

interface Props {
  typ: ProduktTyp;
  title: string;
  description: string;
  intro: string;
}

const { typ, title, intro } = Astro.props;

/* LOAD PRODUCTS */
const entries = await getCollection("produkte");

/* MONEY ENGINE */
// Переименовываем 'top' в 'topProduct', чтобы не конфликтовать с window.top
const { top: topProduct, segments } = buildMoneyPage(entries, typ);

const faq = buildMoneyFaq(typ);

/* NORMALIZE */
function normalize(entry: CollectionEntry<"produkte">): NormalizedProduct {
  return {
    title: entry.data.title,
    teaser: entry.data.teaser,
    image: entry.data.image,
    preis: entry.data.preis,
    currency: entry.data.priceCurrency ?? "EUR",
    featured: entry.data.featured ?? false,
    linkIntern: `/empfehlungen/${entry.data.kategorie}/${entry.slug}/`,
  } as NormalizedProduct;
}

/* FORMAT PRICE */
const formatPrice = (price?: number) =>
  typeof price === "number"
    ? new Intl.NumberFormat("de-DE", {
        style: "currency",
        currency: "EUR",
      }).format(price)
    : "-";
---

<div class="mx-auto max-w-6xl px-4 py-12 md:py-20">
  
  <header class="max-w-3xl mb-16">
    <span class="inline-block px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-[10px] font-black uppercase tracking-[0.2em] mb-4">
      Experten-Berater
    </span>
    <h1 class="text-4xl md:text-6xl font-black text-neutral-900 leading-[1.1] mb-6 tracking-tight">
      {title}
    </h1>
    <p class="text-lg md:text-xl text-neutral-600 leading-relaxed font-medium">
      {intro}
    </p>
  </header>

  {/* TOP EMPFEHLUNG: Premium Hero Look */}
  
  {topProduct && (
  <section>
    <h2>{topProduct.data.title}</h2>
  </section>
)}

  {/* SEGMENTE: Budget, Mittelklasse, Premium */}
  <div class="space-y-24">
    {Object.entries({
      "Günstige Modelle": segments.budget,
      "Mittelklasse": segments.mid,
      "Premium Modelle": segments.premium
    }).map(([label, items]) => (
      items.length > 0 && (
        <section>
          <div class="flex items-center gap-6 mb-12">
             <h2 class="text-2xl md:text-3xl font-black text-neutral-900 tracking-tight whitespace-nowrap">{label}</h2>
             <div class="h-px bg-neutral-100 w-full"></div>
          </div>
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {items.slice(0, 3).map((produkt) => (
              <CategoryProductCard p={normalize(produkt)} />
            ))}
          </div>
        </section>
      )
    ))}
  </div>

  {/* FAQ SECTION */}
  {faq.length > 0 && (
    <section class="mt-32 max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-black text-neutral-900 mb-4 tracking-tight">
          Häufige Fragen <span class="text-blue-600">beantwortet</span>
        </h2>
        <div class="h-1.5 w-20 bg-blue-600 mx-auto rounded-full"></div>
      </div>
      
      <div class="grid gap-6">
        {faq.map((item) => (
          <div class="group bg-neutral-50 p-8 rounded-[32px] border border-neutral-100 hover:bg-white hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500">
            <h3 class="text-lg md:text-xl font-black text-neutral-900 mb-4 flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center font-black">Q</span>
              {item.question}
            </h3>
            <div class="pl-12">
              <p class="text-neutral-600 text-base leading-relaxed font-medium">
                {item.answer}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

</div>