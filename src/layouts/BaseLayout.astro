---
import "../styles/base.css";
import "../styles/global.css";
import "../styles/prose.css";
import "../styles/buttons.css";

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { CollectionEntry } from "astro:content";

interface LayoutProps {
  title?: string;
  description?: string;
  canonical?: string;
  robots?: string;
  ogImage?: string;
  breadcrumb?: { name: string; url: string }[];
  jsonLd?: Record<string, any>[];
  produkt?: CollectionEntry<"produkte">;
  updated?: string;
}

const BASE_URL = "https://yevhenbondarenko.com";

let {
  title,
  description,
  canonical,
  robots = "index, follow",
  ogImage,
  breadcrumb = [],
  jsonLd = [],
  produkt,
  updated,
} = Astro.props as LayoutProps;

const clean = (s: string) => s.trim().replace(/\s+/g, " ");

function safeMetaDescription(src?: string) {
  const base =
    src?.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim() ||
    "Unabhängige Produktübersichten, technische Einordnung und verständliche Vergleiche für Zuhause.";

  return base.length <= 155
    ? base
    : base.slice(0, 155).replace(/\s+\S*$/, "").trim();
}

const currentUrl = new URL(Astro.url.pathname, BASE_URL).toString();
const canonicalUrl = canonical ?? currentUrl;

if (produkt) {
  title = title ?? clean(produkt.data.title);

  description = safeMetaDescription(
    description ??
      produkt.data.description ??
      produkt.data.teaser ??
      produkt.data.title
  );

  if (!ogImage && typeof produkt.data.image === "string") {
    ogImage = new URL(produkt.data.image, BASE_URL).toString();
  }
}

const computedTitle =
  title ?? "Technik Übersichten, Vergleiche & Erklärungen | Yevhen Bondarenko";

const computedDescription = safeMetaDescription(description);

const computedImage =
  ogImage ?? `${BASE_URL}/og/site.webp`;

const dateModified =
  updated ??
  (produkt?.data as any)?.dateModified
  produkt?.data.datum ??
  undefined;

const graph: Record<string, any>[] = [
  {
    "@type": "Organization",
    "@id": `${BASE_URL}/#organization`,
    name: "Bondarenko Empfehlungen",
    url: BASE_URL,
  },
  {
    "@type": "WebSite",
    "@id": `${BASE_URL}/#website`,
    url: BASE_URL,
    name: "Bondarenko Empfehlungen",
    publisher: {
      "@id": `${BASE_URL}/#organization`,
    },
    inLanguage: "de-DE",
  },
  {
    "@type": "WebPage",
    "@id": `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: computedTitle,
    description: computedDescription,
    inLanguage: "de-DE",
    isPartOf: {
      "@id": `${BASE_URL}/#website`,
    },
    ...(dateModified ? { dateModified } : {}),
  },
];

if (breadcrumb.length) {
  graph.push({
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: breadcrumb.map((b, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: b.name,
      item: new URL(b.url, BASE_URL).toString(),
    })),
  });
}

const faq = (produkt?.data as any)?.faq;

if (Array.isArray(faq) && faq.length > 0) {
  graph.push({
    "@type": "FAQPage",
    "@id": `${canonicalUrl}#faq`,
    mainEntity: faq.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.a,
      },
    })),
  });
}

for (const item of jsonLd) {
  graph.push(item);
}

const jsonLdGraph = {
  "@context": "https://schema.org",
  "@graph": graph,
};
---

<!doctype html>
<html lang="de">
  <head>
    <BaseHead
      title={computedTitle}
      description={computedDescription}
      currentUrl={currentUrl}
      canonical={canonicalUrl}
      robots={robots}
      image={computedImage}
      isProduct={!!produkt}
    />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLdGraph)}
    />
  </head>

  <body class="bg-neutral-50 font-sans antialiased text-gray-900">
    <Header />

    <main>
      <slot />
    </main>

    <div class="mx-auto max-w-5xl px-4 py-6 text-sm text-gray-600">
      Hinweis: Diese Website ist kein Online-Shop. Es erfolgt kein Verkauf, keine Lagerhaltung
      und kein Versand von Produkten. Einige Verlinkungen sind Partnerlinks, zum Beispiel zu Amazon.
      Bei einem Kauf über solche Links kann eine Provision anfallen. Für Sie entstehen keine zusätzlichen Kosten.
    </div>

    <Footer />
  </body>
</html>